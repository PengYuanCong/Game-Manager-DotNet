@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登入 - 彭彭遊戲基地</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --rift-bg: #03080d;
            --rift-panel: rgba(6, 22, 31, 0.92);
            --rift-panel-strong: rgba(8, 33, 43, 0.96);
            --rift-line: rgba(31, 230, 246, 0.32);
            --rift-cyan: #23e8ff;
            --rift-gold: #d8b65c;
            --rift-cream: #fff2c8;
            --rift-muted: #8da7b2;
            --rift-danger: #ff5a6c;
            --poro-bg: url("/images/poro-guide.png");
        }

        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            color: #f4fbff;
            font-family: "Microsoft JhengHei", "Noto Sans TC", "Segoe UI", sans-serif;
            background:
                radial-gradient(circle at 18% 18%, rgba(35, 232, 255, 0.16), transparent 24rem),
                radial-gradient(circle at 82% 78%, rgba(216, 182, 92, 0.13), transparent 26rem),
                linear-gradient(135deg, #02060a 0%, #051823 54%, #020509 100%);
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(rgba(35, 232, 255, 0.045) 1px, transparent 1px),
                linear-gradient(90deg, rgba(35, 232, 255, 0.045) 1px, transparent 1px);
            background-size: 44px 44px;
            mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
        }

        .auth-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(320px, 0.9fr) minmax(360px, 520px);
            gap: clamp(28px, 6vw, 88px);
            align-items: center;
            width: min(1180px, calc(100% - 40px));
            margin: 0 auto;
            padding: 48px 0;
            position: relative;
        }

        .back-link {
            position: fixed;
            top: 22px;
            left: 22px;
            z-index: 5;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 42px;
            padding: 8px 14px;
            color: var(--rift-cyan);
            text-decoration: none;
            border: 1px solid var(--rift-line);
            background: rgba(4, 18, 25, 0.72);
            box-shadow: 0 0 22px rgba(35, 232, 255, 0.12);
        }

        .back-link:hover {
            color: #061018;
            background: var(--rift-cyan);
        }

        .auth-lore {
            position: relative;
            min-height: 620px;
            padding: 42px;
            border: 1px solid rgba(216, 182, 92, 0.32);
            background-image:
                linear-gradient(135deg, rgba(1, 9, 15, 0.92), rgba(5, 28, 40, 0.78)),
                var(--poro-bg),
                repeating-linear-gradient(90deg, rgba(35, 232, 255, 0.06) 0 1px, transparent 1px 78px);
            background-position:
                center,
                right 30px bottom 28px,
                center;
            background-size:
                auto,
                min(42vw, 280px) auto,
                78px 78px;
            background-repeat:
                no-repeat,
                no-repeat,
                repeat;
            box-shadow: 0 24px 90px rgba(0, 0, 0, 0.44);
            overflow: hidden;
        }

        .auth-lore::before {
            content: "";
            position: absolute;
            width: 520px;
            height: 520px;
            right: -160px;
            bottom: -140px;
            border: 1px solid rgba(216, 182, 92, 0.38);
            border-radius: 50%;
            box-shadow: inset 0 0 44px rgba(35, 232, 255, 0.08);
        }

        .auth-kicker {
            color: var(--rift-cyan);
            font-size: 0.78rem;
            font-weight: 900;
            letter-spacing: 0;
            text-transform: uppercase;
        }

        .auth-lore h1 {
            max-width: 560px;
            margin: 16px 0 18px;
            color: var(--rift-cream);
            font-size: clamp(3rem, 7vw, 6.6rem);
            font-weight: 950;
            line-height: 0.94;
        }

        .auth-lore p {
            max-width: 520px;
            color: #c8e5ee;
            font-size: 1.04rem;
            line-height: 1.9;
        }

        .auth-stat-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 28px;
        }

        .auth-stat-row span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 7px 12px;
            border: 1px solid rgba(35, 232, 255, 0.34);
            color: #eaffff;
            background: rgba(0, 0, 0, 0.24);
            font-weight: 800;
        }

        .poro-orbit {
            position: relative;
            z-index: 1;
            margin: 34px auto 0;
            width: 184px;
            height: 184px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(35, 232, 255, 0.17), transparent 68%);
            animation: floatPoro 5s ease-in-out infinite;
        }

        .poro {
            position: relative;
            width: 112px;
            height: 98px;
            border-radius: 48% 48% 44% 44%;
            background: #fff4df;
            border: 4px solid #32dff0;
            box-shadow: 0 14px 30px rgba(35, 232, 255, 0.22);
        }

        .poro::before,
        .poro::after {
            content: "";
            position: absolute;
            top: -8px;
            width: 24px;
            height: 26px;
            background: #caa978;
            border-radius: 65% 35% 45% 55%;
            border: 3px solid #9a7848;
        }

        .poro::before {
            left: 12px;
            transform: rotate(-38deg);
        }

        .poro::after {
            right: 12px;
            transform: rotate(38deg) scaleX(-1);
        }

        .poro-eye {
            position: absolute;
            top: 35px;
            width: 12px;
            height: 15px;
            border-radius: 50%;
            background: #10233a;
        }

        .poro-eye.left {
            left: 31px;
        }

        .poro-eye.right {
            right: 31px;
        }

        .poro-nose {
            position: absolute;
            top: 52px;
            left: 50%;
            width: 14px;
            height: 10px;
            border-radius: 50%;
            background: #6d4f42;
            transform: translateX(-50%);
        }

        .poro-tongue {
            position: absolute;
            left: 50%;
            bottom: 13px;
            width: 22px;
            height: 24px;
            border-radius: 0 0 16px 16px;
            background: #ff777f;
            transform: translateX(-50%);
        }

        .auth-card {
            position: relative;
            padding: 34px;
            border: 1px solid rgba(35, 232, 255, 0.46);
            background:
                linear-gradient(180deg, var(--rift-panel-strong), var(--rift-panel)),
                repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.04) 0 1px, transparent 1px 18px);
            box-shadow:
                0 28px 90px rgba(0, 0, 0, 0.54),
                0 0 0 1px rgba(216, 182, 92, 0.1) inset;
        }

        .auth-card::after {
            content: "";
            position: absolute;
            right: -1px;
            bottom: -1px;
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, transparent 0 50%, var(--rift-cyan) 51%);
            opacity: 0.8;
        }

        .auth-card-header {
            margin-bottom: 26px;
        }

        .auth-card-header h2 {
            margin: 7px 0 8px;
            color: #ffffff;
            font-size: 2.1rem;
            font-weight: 950;
        }

        .auth-card-header p {
            margin: 0;
            color: var(--rift-muted);
            line-height: 1.7;
        }

        .auth-alert {
            border-radius: 0;
            border: 1px solid rgba(255, 90, 108, 0.48);
            background: rgba(255, 90, 108, 0.16);
            color: #ffd6dc;
        }

        .auth-success {
            border-color: rgba(99, 255, 193, 0.5);
            background: rgba(99, 255, 193, 0.14);
            color: #c9ffe8;
        }

        .form-label {
            color: var(--rift-cyan);
            font-size: 0.86rem;
            font-weight: 900;
        }

        .auth-input {
            min-height: 52px;
            color: #ffffff;
            border-radius: 0;
            border: 1px solid rgba(162, 188, 198, 0.4);
            background: rgba(255, 255, 255, 0.075);
        }

        .auth-input:focus {
            color: #ffffff;
            border-color: var(--rift-cyan);
            background: rgba(35, 232, 255, 0.08);
            box-shadow: 0 0 0 0.18rem rgba(35, 232, 255, 0.16);
        }

        .auth-input::placeholder {
            color: rgba(220, 239, 246, 0.48);
        }

        .auth-submit {
            min-height: 54px;
            border-radius: 0;
            border: 1px solid rgba(35, 232, 255, 0.85);
            background: linear-gradient(135deg, #18d5f0, #9ee996);
            color: #031017;
            font-weight: 950;
            box-shadow: 0 18px 38px rgba(35, 232, 255, 0.2);
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .auth-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 44px rgba(35, 232, 255, 0.28);
        }

        .auth-switch {
            margin-top: 18px;
            color: var(--rift-muted);
        }

        .auth-switch a {
            color: var(--rift-gold);
            font-weight: 900;
            text-decoration: none;
        }

        .auth-switch a:hover {
            color: var(--rift-cream);
        }

        @@keyframes floatPoro {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-12px);
            }
        }

        @@media (max-width: 980px) {
            .auth-shell {
                grid-template-columns: 1fr;
                padding-top: 92px;
            }

            .auth-lore {
                min-height: 420px;
            }
        }

        @@media (max-width: 560px) {
            .auth-shell {
                width: min(100% - 24px, 1180px);
            }

            .auth-lore,
            .auth-card {
                padding: 24px;
            }

            .poro-orbit {
                margin-top: 28px;
            }
        }
    </style>
</head>
<body class="auth-page">
    <a href="/" class="back-link">
        <i class="bi bi-arrow-left"></i>
        返回基地
    </a>

    <main class="auth-shell">
        <section class="auth-lore auth-aside" aria-label="網站介紹">
            <div class="auth-kicker">ARAM MAYHEM COMMAND CENTER</div>
            <h1>回到你的配裝基地</h1>
            <p>
                登入後可以保存 AI 推薦、裝備組合與個人查詢紀錄，讓下次大亂鬥選到同樣英雄與海克斯時更快找到方向。
            </p>
            <div class="auth-stat-row" aria-label="功能摘要">
                <span><i class="bi bi-stars"></i>AI 推薦</span>
                <span><i class="bi bi-gem"></i>海克斯知識庫</span>
                <span><i class="bi bi-box-seam"></i>裝備組合</span>
            </div>
            <div class="poro-orbit" aria-hidden="true">
                <div class="poro">
                    <span class="poro-eye left"></span>
                    <span class="poro-eye right"></span>
                    <span class="poro-nose"></span>
                    <span class="poro-tongue"></span>
                </div>
            </div>
        </section>

        <section class="auth-card auth-panel" aria-label="登入表單">
            <div class="auth-card-header">
                <div class="auth-kicker">SUMMONER LOGIN</div>
                <h2>登入帳號</h2>
                <p>輸入帳號密碼，繼續管理你的 ARAM Mayhem 推薦資料。</p>
            </div>

            @if (TempData["SuccessMsg"] != null)
            {
                <div class="alert auth-success py-2 fw-bold" role="alert">
                    <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMsg"]
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert auth-alert py-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label" for="username">
                        <i class="bi bi-person-badge me-1"></i>使用者帳號
                    </label>
                    <input id="username" type="text" name="username" class="form-control auth-input" required autocomplete="username" placeholder="輸入你的召喚師代號">
                </div>
                <div class="mb-4">
                    <label class="form-label" for="password">
                        <i class="bi bi-shield-lock me-1"></i>密碼
                    </label>
                    <input id="password" type="password" name="password" class="form-control auth-input" required autocomplete="current-password" placeholder="輸入通行密碼">
                </div>
                <button type="submit" class="btn auth-submit w-100">
                    進入基地 <i class="bi bi-box-arrow-in-right ms-1"></i>
                </button>

                <div class="auth-switch text-center">
                    還沒有帳號？
                    <a asp-action="Register">建立新的玩家檔案</a>
                </div>
            </form>
        </section>
    </main>
</body>
</html>
