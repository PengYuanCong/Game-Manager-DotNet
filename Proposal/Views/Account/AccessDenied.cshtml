@{
    ViewData["Title"] = "權限不足";
}

<div class="container text-center" style="padding-top: 96px; padding-bottom: 96px;">
    <div class="mb-4">
        <i class="bi bi-shield-lock display-1 text-warning"></i>
    </div>

    <h1 class="text-warning fw-bold mb-3">權限不足</h1>
    <p class="text-secondary mb-4">
        這個功能只有管理員可以使用。如果你剛被設定為管理員，請先登出再重新登入，讓新的權限寫進登入 Cookie。
    </p>

    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn btn-info text-dark fw-bold px-4">
            <i class="bi bi-house-door-fill me-1"></i>返回首頁
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-warning px-4">
                <i class="bi bi-box-arrow-right me-1"></i>重新登入
            </button>
        </form>
    </div>
</div>
