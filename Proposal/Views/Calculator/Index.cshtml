@{
    ViewData["Title"] = "公式計算";
}

<section class="formula-workshop">
    <div id="calculatorAntiForgeryToken" class="d-none">
        @Html.AntiForgeryToken()
    </div>

    <div class="formula-hero">
        <div>
            <div class="formula-kicker">RIFT NUMBERS LAB</div>
            <h1>公式計算工坊</h1>
            <p>快速估算裝備金錢效率、減傷、有效生命值與穿透後傷害倍率，讓配裝不只靠感覺。</p>
        </div>
        <div class="formula-runes" aria-hidden="true">
            <span><i class="bi bi-currency-dollar"></i>效率</span>
            <span><i class="bi bi-shield-shaded"></i>減傷</span>
            <span><i class="bi bi-heart-pulse"></i>EHP</span>
            <span><i class="bi bi-crosshair"></i>穿透</span>
        </div>
    </div>

    <div class="formula-layout">
        <aside class="formula-console">
            <div class="console-section">
                <label class="form-label" for="formulaType">計算公式</label>
                <select id="formulaType" class="form-select rift-select" onchange="changeInputs()">
                    <option value="">選擇要計算的項目</option>
                    <option value="cp">裝備金錢效率</option>
                    <option value="dr">減傷百分比</option>
                    <option value="ehp">有效生命值 (EHP)</option>
                    <option value="pen">穿透後減傷 / 傷害倍率</option>
                </select>
            </div>

            <div class="console-section">
                <div class="section-title">
                    <i class="bi bi-box-seam"></i>
                    裝備快載
                </div>

                <label class="form-label" for="equipmentSelector">單件裝備</label>
                <select id="equipmentSelector" class="form-select rift-select mb-3">
                    <option value="">選擇單件裝備</option>
                    @if (ViewBag.EquipmentList != null)
                    {
                        foreach (var item in ViewBag.EquipmentList)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </select>

                <label class="form-label" for="loadoutSelector">基礎組合</label>
                <select id="loadoutSelector" class="form-select rift-select mb-3">
                    <option value="">選擇基礎組合</option>
                    @if (ViewBag.LoadoutList != null)
                    {
                        foreach (var lo in (List<Proposal.Models.Loadout>)ViewBag.LoadoutList)
                        {
                            <option value="@lo.Id">@lo.LoadoutName</option>
                        }
                    }
                </select>

                <button type="button" id="btnLoadData" class="btn rift-primary w-100" onclick="handleDataLoading()">
                    <i class="bi bi-download me-1"></i>帶入數值
                </button>
            </div>

            <div class="console-section">
                <div class="section-title">
                    <i class="bi bi-intersect"></i>
                    組合對比
                </div>
                <label class="form-label" for="compareLoadoutSelector">對比組合</label>
                <select id="compareLoadoutSelector" class="form-select rift-select mb-3">
                    <option value="">選擇要對比的組合</option>
                    @if (ViewBag.LoadoutList != null)
                    {
                        foreach (var lo in (List<Proposal.Models.Loadout>)ViewBag.LoadoutList)
                        {
                            <option value="@lo.Id">@lo.LoadoutName</option>
                        }
                    }
                </select>
                <button type="button" id="btnCompareData" class="btn rift-outline w-100" onclick="handleComparison()">
                    <i class="bi bi-diagram-3 me-1"></i>開始對比
                </button>
            </div>
        </aside>

        <main class="formula-main">
            <section class="formula-input-card">
                <div class="panel-heading">
                    <span>01</span>
                    <div>
                        <h2>輸入參數</h2>
                        <p>可手動輸入，也可以從左側裝備庫直接帶入。</p>
                    </div>
                </div>
                <div id="input-fields" class="formula-input-fields">
                    <div class="empty-state">
                        <i class="bi bi-arrow-up-circle"></i>
                        <strong>先選擇公式</strong>
                        <span>選定公式後，這裡會切換成對應的輸入欄位。</span>
                    </div>
                </div>
                <button type="button" id="btnCalculate" class="btn rift-primary btn-lg w-100 mt-3" style="display:none;">
                    <i class="bi bi-play-circle-fill me-2"></i>開始計算
                </button>
            </section>

            <section class="formula-result-grid d-none" id="displayArea">
                <article id="resultArea" class="result-card">
                    <div class="panel-heading compact">
                        <span>02</span>
                        <h2>計算結果</h2>
                    </div>
                    <div id="resultValue" class="result-value">--</div>
                </article>

                <article class="chart-card">
                    <div class="panel-heading compact">
                        <span>03</span>
                        <h2>屬性分佈雷達圖</h2>
                    </div>
                    <div class="chart-shell">
                        <canvas id="attributeChart"></canvas>
                    </div>
                </article>
            </section>
        </main>
    </div>
</section>

