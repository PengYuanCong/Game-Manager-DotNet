@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let myRadarChart = null;

        function normalizeStats(data) {
            return {
                hp: Number(data.hp || 0),
                mana: Number(data.mana || 0),
                attack: Number(data.attack || 0),
                magicAttack: Number(data.magicAttack || 0),
                pDef: Number(data.physicalDefense || data.pDef || 0),
                mDef: Number(data.magicDefense || data.mDef || 0),
                healthRegen: Number(data.healthRegen || 0),
                manaRegen: Number(data.manaRegen || 0),
                abilityHaste: Number(data.abilityHaste || 0),
                attackSpeed: Number(data.attackSpeed || 0),
                criticalStrikeChance: Number(data.criticalStrikeChance || 0),
                moveSpeed: Number(data.moveSpeed || 0),
                moveSpeedPercent: Number(data.moveSpeedPercent || 0),
                lethality: Number(data.lethality || 0),
                armorPenetrationPercent: Number(data.armorPenetrationPercent || 0),
                magicPenetration: Number(data.magicPenetration || 0),
                magicPenetrationPercent: Number(data.magicPenetrationPercent || 0),
                lifeSteal: Number(data.lifeSteal || 0),
                omnivamp: Number(data.omnivamp || 0),
                healAndShieldPower: Number(data.healAndShieldPower || 0),
                tenacity: Number(data.tenacity || 0),
                price: Number(data.price || 0)
            };
        }

        const statGoldWeights = {
            hp: 2.67,
            mana: 1.4,
            attack: 35,
            magicAttack: 21.75,
            pDef: 20,
            mDef: 18,
            healthRegen: 3,
            manaRegen: 5,
            abilityHaste: 50,
            attackSpeed: 25,
            criticalStrikeChance: 40,
            moveSpeed: 12,
            moveSpeedPercent: 39.5,
            lethality: 5,
            armorPenetrationPercent: 41.67,
            magicPenetration: 31.1,
            magicPenetrationPercent: 46.15,
            lifeSteal: 37.5,
            omnivamp: 45,
            healAndShieldPower: 30,
            tenacity: 30
        };

        function statGoldValue(stats) {
            return stats.hp * statGoldWeights.hp
                + stats.mana * statGoldWeights.mana
                + stats.attack * statGoldWeights.attack
                + stats.magicAttack * statGoldWeights.magicAttack
                + stats.pDef * statGoldWeights.pDef
                + stats.mDef * statGoldWeights.mDef
                + stats.healthRegen * statGoldWeights.healthRegen
                + stats.manaRegen * statGoldWeights.manaRegen
                + stats.abilityHaste * statGoldWeights.abilityHaste
                + stats.attackSpeed * statGoldWeights.attackSpeed
                + stats.criticalStrikeChance * statGoldWeights.criticalStrikeChance
                + stats.moveSpeed * statGoldWeights.moveSpeed
                + stats.moveSpeedPercent * statGoldWeights.moveSpeedPercent
                + stats.lethality * statGoldWeights.lethality
                + stats.armorPenetrationPercent * statGoldWeights.armorPenetrationPercent
                + stats.magicPenetration * statGoldWeights.magicPenetration
                + stats.magicPenetrationPercent * statGoldWeights.magicPenetrationPercent
                + stats.lifeSteal * statGoldWeights.lifeSteal
                + stats.omnivamp * statGoldWeights.omnivamp
                + stats.healAndShieldPower * statGoldWeights.healAndShieldPower
                + stats.tenacity * statGoldWeights.tenacity;
        }

        function damageTakenMultiplier(resist) {
            if (resist >= 0) {
                return 100 / (100 + resist);
            }

            return 2 - 100 / (100 - resist);
        }

        function damageReductionPercent(resist) {
            return (1 - damageTakenMultiplier(resist)) * 100;
        }

        function effectiveResistanceAfterPenetration(resist, percentPen, flatPen) {
            if (resist <= 0) {
                return resist;
            }

            const percent = Math.min(Math.max(percentPen, 0), 100) / 100;
            const afterPercent = resist * (1 - percent);
            return Math.max(0, afterPercent - Math.max(flatPen, 0));
        }

        function changeInputs() {
            const type = document.getElementById("formulaType").value;
            const container = document.getElementById("input-fields");
            const btn = document.getElementById("btnCalculate");
            const displayArea = document.getElementById("displayArea");

            container.innerHTML = "";
            displayArea.classList.add("d-none");
            btn.style.display = type === "" ? "none" : "block";

            if (type === "cp") {
                container.innerHTML = `
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="input_param1">理論屬性金錢價值</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param1" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="input_param2">裝備總價格</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param2" required>
                        </div>
                    </div>
                    <p class="formula-help mt-3 mb-0">只計算可量化素質；主動、被動與英雄適配度會交給 AI 推薦補判斷。</p>`;
            } else if (type === "dr") {
                container.innerHTML = `
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="input_param1">物理防禦</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param1" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="input_param2">魔法防禦</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param2" required>
                        </div>
                    </div>`;
            } else if (type === "ehp") {
                container.innerHTML = `
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="input_param1">生命值</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param1" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="input_param2">物理防禦</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param2" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="input_param3">魔法防禦</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param3" required>
                        </div>
                    </div>`;
            } else if (type === "pen") {
                container.innerHTML = `
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="input_param1">目標原始抗性</label>
                            <input type="number" step="0.01" value="100" class="form-control calc-input" id="input_param1" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="input_param2">百分比穿透 %</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param2" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="input_param3">固定穿透</label>
                            <input type="number" step="0.01" class="form-control calc-input" id="input_param3" required>
                        </div>
                    </div>
                    <p class="formula-help mt-3 mb-0">估算物穿或魔穿：先套用百分比穿透，再套用固定穿透，且穿透不會把正抗性壓成負值。</p>`;
            } else {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-arrow-up-circle"></i>
                        <strong>先選擇公式</strong>
                        <span>選定公式後，這裡會切換成對應的輸入欄位。</span>
                    </div>`;
            }
        }

        function updateRadarChart(baseStats, compareStats = null) {
            const ctx = document.getElementById("attributeChart").getContext("2d");
            if (myRadarChart) {
                myRadarChart.destroy();
            }

            const datasets = [{
                label: "基礎組合/裝備",
                data: [
                    baseStats.hp,
                    baseStats.attack,
                    baseStats.magicAttack,
                    baseStats.pDef + baseStats.mDef,
                    baseStats.lethality + baseStats.armorPenetrationPercent + baseStats.magicPenetration + baseStats.magicPenetrationPercent,
                    baseStats.abilityHaste + baseStats.attackSpeed + baseStats.criticalStrikeChance,
                    baseStats.lifeSteal + baseStats.omnivamp + baseStats.healAndShieldPower + baseStats.healthRegen + baseStats.manaRegen
                ],
                backgroundColor: "rgba(34, 232, 255, 0.18)",
                borderColor: "#22e8ff",
                borderWidth: 2,
                pointBackgroundColor: "#fff6cf"
            }];

            if (compareStats) {
                datasets.push({
                    label: "對比組合",
                    data: [
                        compareStats.hp,
                        compareStats.attack,
                        compareStats.magicAttack,
                        compareStats.pDef + compareStats.mDef,
                        compareStats.lethality + compareStats.armorPenetrationPercent + compareStats.magicPenetration + compareStats.magicPenetrationPercent,
                        compareStats.abilityHaste + compareStats.attackSpeed + compareStats.criticalStrikeChance,
                        compareStats.lifeSteal + compareStats.omnivamp + compareStats.healAndShieldPower + compareStats.healthRegen + compareStats.manaRegen
                    ],
                    backgroundColor: "rgba(216, 182, 92, 0.18)",
                    borderColor: "#d8b65c",
                    borderWidth: 2,
                    pointBackgroundColor: "#fff6cf"
                });
            }

            myRadarChart = new Chart(ctx, {
                type: "radar",
                data: {
                    labels: ["生命值", "物理攻擊", "魔法攻擊", "雙防", "穿透", "輸出效率", "續戰輔助"],
                    datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            angleLines: { color: "rgba(255,255,255,0.12)" },
                            grid: { color: "rgba(255,255,255,0.12)" },
                            pointLabels: { color: "#d8edf4", font: { size: 12, weight: "bold" } },
                            ticks: { display: false, count: 5 }
                        }
                    },
                    plugins: {
                        legend: {
                            display: compareStats !== null,
                            labels: { color: "#f5fbff" }
                        }
                    }
                }
            });
        }

        function handleDataLoading() {
            const formulaType = document.getElementById("formulaType").value;
            const eqId = document.getElementById("equipmentSelector").value;
            const loadoutId = document.getElementById("loadoutSelector").value;

            if (!formulaType) {
                alert("請先選擇計算公式。");
                return;
            }

            if (!eqId && !loadoutId) {
                alert("請從單件裝備或基礎組合中擇一選取。");
                return;
            }

            const btn = document.getElementById("btnLoadData");
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btn.disabled = true;

            const fetchUrl = loadoutId ? `/Equipment/GetLoadoutStats?loadoutId=${loadoutId}` : `/Equipment/GetEquipmentDetails/${eqId}`;

            fetch(fetchUrl)
                .then(res => res.json())
                .then(data => {
                    if (!data) {
                        return;
                    }

                    const stats = normalizeStats(data);

                    if (formulaType === "cp") {
                        document.getElementById("input_param1").value = statGoldValue(stats).toFixed(2);
                        document.getElementById("input_param2").value = stats.price;
                    } else if (formulaType === "dr") {
                        document.getElementById("input_param1").value = stats.pDef;
                        document.getElementById("input_param2").value = stats.mDef;
                    } else if (formulaType === "ehp") {
                        document.getElementById("input_param1").value = stats.hp;
                        document.getElementById("input_param2").value = stats.pDef;
                        document.getElementById("input_param3").value = stats.mDef;
                    } else if (formulaType === "pen") {
                        document.getElementById("input_param1").value = document.getElementById("input_param1").value || 100;
                        document.getElementById("input_param2").value = Math.max(stats.armorPenetrationPercent, stats.magicPenetrationPercent);
                        document.getElementById("input_param3").value = Math.max(stats.lethality, stats.magicPenetration);
                    }

                    document.getElementById("displayArea").classList.remove("d-none");
                    updateRadarChart(stats);
                })
                .catch(err => console.error(err))
                .finally(() => {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                });
        }

        async function handleComparison() {
            const baseId = document.getElementById("loadoutSelector").value;
            const compareId = document.getElementById("compareLoadoutSelector").value;

            if (!baseId || !compareId) {
                alert("請分別選擇基礎組合與對比組合。");
                return;
            }

            const btn = document.getElementById("btnCompareData");
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btn.disabled = true;

            try {
                const [res1, res2] = await Promise.all([
                    fetch(`/Equipment/GetLoadoutStats?loadoutId=${baseId}`),
                    fetch(`/Equipment/GetLoadoutStats?loadoutId=${compareId}`)
                ]);

                const baseData = await res1.json();
                const compareData = await res2.json();
                const stats1 = normalizeStats(baseData);
                const stats2 = normalizeStats(compareData);

                document.getElementById("displayArea").classList.remove("d-none");
                updateRadarChart(stats1, stats2);
            } catch (err) {
                console.error("對比載入失敗", err);
                alert("載入對比資料時發生錯誤。");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        document.getElementById("btnCalculate").addEventListener("click", function () {
            const formulaSelect = document.getElementById("formulaType");
            const type = formulaSelect.value;
            const typeText = formulaSelect.options[formulaSelect.selectedIndex].text;

            const p1 = parseFloat(document.getElementById("input_param1")?.value) || 0;
            const p2 = parseFloat(document.getElementById("input_param2")?.value) || 0;
            const p3 = parseFloat(document.getElementById("input_param3")?.value) || 0;

            let result = "";
            if (type === "cp") {
                if (p2 === 0) {
                    alert("裝備價格不能為 0。");
                    return;
                }

                const efficiency = p1 / p2 * 100;
                result = `理論金錢效率：${efficiency.toFixed(1)}% <br> 屬性價值：約 ${p1.toFixed(0)} 金`;
            } else if (type === "dr") {
                result = `物理減傷：${damageReductionPercent(p1).toFixed(1)}% <br> 魔法減傷：${damageReductionPercent(p2).toFixed(1)}%`;
            } else if (type === "ehp") {
                result = `面對物理傷害 EHP：${(p1 / damageTakenMultiplier(p2)).toFixed(0)} <br> 面對魔法傷害 EHP：${(p1 / damageTakenMultiplier(p3)).toFixed(0)}`;
            } else if (type === "pen") {
                const effectiveResist = effectiveResistanceAfterPenetration(p1, p2, p3);
                const beforeMultiplier = damageTakenMultiplier(p1);
                const afterMultiplier = damageTakenMultiplier(effectiveResist);
                result = `穿透後抗性：${effectiveResist.toFixed(1)} <br> 減傷：${damageReductionPercent(effectiveResist).toFixed(1)}% <br> 傷害倍率提升：${(afterMultiplier / beforeMultiplier).toFixed(2)}x`;
            }

            document.getElementById("resultValue").innerHTML = result;
            document.getElementById("displayArea").classList.remove("d-none");

            const inputsString = type === "cp"
                ? `理論金錢價值: ${p1} , 價格: ${p2}`
                : type === "dr"
                    ? `物防: ${p1} , 魔防: ${p2}`
                    : type === "pen"
                        ? `抗性: ${p1} , 百分比穿透: ${p2} , 固定穿透: ${p3}`
                        : `HP: ${p1} , 物防: ${p2} , 魔防: ${p3}`;

            const antiForgeryToken = document.querySelector('#calculatorAntiForgeryToken input[name="__RequestVerificationToken"]')?.value || "";

            fetch("/Calculator/SaveRecord", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                    "RequestVerificationToken": antiForgeryToken
                },
                body: new URLSearchParams({
                    type: typeText,
                    inputs: inputsString,
                    result: result.replaceAll("<br>", " | ")
                })
            });
        });

        window.onload = changeInputs;
    </script>
}
