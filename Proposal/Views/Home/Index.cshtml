@{
    ViewData["Title"] = "ARAM Mayhem 決策工具";
}

<div class="home-page game-page">
    <section class="home-command" aria-labelledby="home-title">
        <div class="home-command__copy">
            <span class="game-kicker">ARAM MAYHEM DECISION LAB</span>
            <h1 id="home-title">本輪海克斯，選得更有把握</h1>
            <p>
                鎖定英雄、帶入眼前的三個選項，快速取得海克斯優先級、選擇理由與裝備方向。
                不需要先讀完整資料庫，也不用在對局中來回翻攻略。
            </p>

            <div class="home-command__actions">
                <a class="btn btn-primary-game btn-lg" asp-controller="AiRecommendation" asp-action="Index">
                    <i class="bi bi-stars" aria-hidden="true"></i>
                    開始 AI 推薦
                </a>
                <a class="btn btn-outline-game btn-lg" asp-controller="LolAramGuides" asp-action="Index">
                    <i class="bi bi-person-vcard" aria-hidden="true"></i>
                    瀏覽英雄
                </a>
            </div>

            <dl class="home-command__facts" aria-label="推薦系統特色">
                <div>
                    <dt>三選一</dt>
                    <dd>只比較本輪實際出現的海克斯</dd>
                </div>
                <div>
                    <dt>本機 RAG</dt>
                    <dd>英雄、套裝與人工標註先參與判斷</dd>
                </div>
                <div>
                    <dt>繁中結果</dt>
                    <dd>推薦理由與裝備名稱維持繁體中文</dd>
                </div>
            </dl>
        </div>

        <div class="home-mission" aria-label="AI 推薦流程">
            <div class="home-mission__heading">
                <div>
                    <span class="game-section-label">本場任務</span>
                    <h2>把這輪的選項交給普羅助手</h2>
                </div>
                <span class="home-mission__status">
                    <i class="bi bi-broadcast-pin" aria-hidden="true"></i>
                    推薦系統待命
                </span>
            </div>

            <ol class="home-mission__steps">
                <li>
                    <span class="home-mission__number">01</span>
                    <div>
                        <strong>選擇英雄</strong>
                        <small>先確認技能觸發方式、傷害型態與隊伍功能。</small>
                    </div>
                    <i class="bi bi-person-bounding-box" aria-hidden="true"></i>
                </li>
                <li>
                    <span class="home-mission__number">02</span>
                    <div>
                        <strong>比較三個海克斯</strong>
                        <small>帶入本輪實際選項，後續階段會參考先前選擇。</small>
                    </div>
                    <i class="bi bi-gem" aria-hidden="true"></i>
                </li>
                <li>
                    <span class="home-mission__number">03</span>
                    <div>
                        <strong>取得推薦</strong>
                        <small>查看最佳選擇、搭配原因、裝備方向與注意事項。</small>
                    </div>
                    <i class="bi bi-check2-circle" aria-hidden="true"></i>
                </li>
            </ol>

            <div class="poro-guide">
                <img src="/images/poro-guide.png" alt="揮手提示的普羅推薦助手" width="210" height="210">
                <div>
                    <strong>不確定名稱也沒關係</strong>
                    <p>英雄和海克斯欄位都能跳到資料頁點選，再自動帶回推薦頁。</p>
                </div>
            </div>
        </div>
    </section>

    <section class="home-library" aria-labelledby="library-title">
        <div class="home-library__intro">
            <span class="game-kicker">戰前資料</span>
            <h2 id="library-title">先查資料，或直接進入本場決策</h2>
            <p>三個資料庫共用同一套搜尋邏輯，讓推薦結果可以追溯到英雄定位、海克斯屬性與裝備效果。</p>
        </div>

        <div class="home-library-grid">
            <a class="home-library-card home-library-card--primary game-card" asp-controller="LolAramGuides" asp-action="Index">
                <div class="home-library-card__icon"><i class="bi bi-person-vcard" aria-hidden="true"></i></div>
                <div>
                    <span>英雄資料庫</span>
                    <strong>從角色定位開始規劃這一場</strong>
                    <p>查看人工判斷、推薦海克斯、核心裝備與對局注意事項。</p>
                </div>
                <i class="bi bi-arrow-up-right" aria-hidden="true"></i>
            </a>

            <a class="home-library-card game-card" asp-controller="LolAramAugments" asp-action="Index">
                <div class="home-library-card__icon"><i class="bi bi-gem" aria-hidden="true"></i></div>
                <div>
                    <span>海克斯資料庫</span>
                    <strong>依評級、套裝與屬性快速篩選</strong>
                </div>
                <i class="bi bi-arrow-up-right" aria-hidden="true"></i>
            </a>

            <a class="home-library-card game-card" asp-controller="Equipment" asp-action="Index">
                <div class="home-library-card__icon"><i class="bi bi-shield-shaded" aria-hidden="true"></i></div>
                <div>
                    <span>裝備資料庫</span>
                    <strong>比較效果、屬性與儲存組合</strong>
                </div>
                <i class="bi bi-arrow-up-right" aria-hidden="true"></i>
            </a>
        </div>
    </section>
</div>
