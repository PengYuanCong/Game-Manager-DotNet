@{
    Layout = "_Layout";
    ViewData["Title"] = "找不到頁面";
}

<section class="error-page" aria-labelledby="error-title">
    <div class="error-page__copy">
        <span class="game-kicker">ERROR 404</span>
        <h1 id="error-title">這條路線沒有資料</h1>
        <p>頁面可能已經移動、網址輸入錯誤，或這筆資料尚未建立。可以回到基地重新選擇功能。</p>

        <div class="error-page__actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary-game btn-lg">
                <i class="bi bi-house-door-fill" aria-hidden="true"></i>
                返回首頁
            </a>
            <button type="button" onclick="history.back()" class="btn btn-outline-game btn-lg">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                回上一頁
            </button>
        </div>
    </div>

    <div class="error-page__media" aria-hidden="true">
        <span>404</span>
        <img src="/images/404cat.jpg" alt="">
    </div>
</section>
