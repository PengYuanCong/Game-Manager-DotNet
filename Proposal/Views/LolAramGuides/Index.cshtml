    .guide-card-footer {
        justify-content: space-between;
        margin-top: auto;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding-top: 12px;
    }

    .updated-time {
        color: #8ea5ae;
        font-size: 0.82rem;
    }

    .icon-action {
        width: 34px;
        height: 34px;
        display: inline-grid;
        place-items: center;
        color: #e9fbff;
