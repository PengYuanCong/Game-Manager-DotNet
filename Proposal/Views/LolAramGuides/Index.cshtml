@model IReadOnlyList<Proposal.Models.LolAramGuide>

@{
    ViewData["Title"] = "英雄 RAG 知識庫";
    var isAdmin = User.IsInRole("Admin");
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
    var pickMode = ViewData["PickMode"]?.ToString();
    var isPickMode = string.Equals(pickMode, "champion", StringComparison.OrdinalIgnoreCase);
    var augmentCatalog = ViewData["AugmentCatalog"] as IReadOnlyDictionary<string, Proposal.Models.LolAramAugment>
        ?? new Dictionary<string, Proposal.Models.LolAramAugment>(StringComparer.OrdinalIgnoreCase);

    static IReadOnlyList<Proposal.Services.LolAramGuideAugmentBadge> ParseAugmentBadges(
        string? value,
        IReadOnlyDictionary<string, Proposal.Models.LolAramAugment> catalog)
    {
        return Proposal.Services.LolAramGuideAugmentParser.Parse(value, catalog);
    }

    static string RarityClass(string? value)
    {
        return value?.Trim().ToLowerInvariant() switch
        {
            "prismatic" or "稜彩" or "稜彩階" or "彩色" => "rarity-prismatic",
            "gold" or "黃金" or "黃金階" or "金色" => "rarity-gold",
            "silver" or "白銀" or "白銀階" or "白色" => "rarity-silver",
            _ => "rarity-unknown"
        };
    }

    static string TierClass(string? tier)
    {
        return tier?.Trim().ToUpperInvariant() switch
        {
            "S" or "S+" or "S-" => "tier-s",
            "A" or "A+" or "A-" => "tier-a",
            "B" or "B+" or "B-" => "tier-b",
            _ => "tier-other"
        };
    }

    static IReadOnlyList<string> SplitValues(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? Array.Empty<string>()
            : value.Split(new[] { '；', ';', ',', '，', '、' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    static IReadOnlyList<string> BuildChampionImageUrls(Proposal.Models.LolAramGuide guide)
    {
        var candidates = new List<string>();
        AddChampionCandidate(candidates, guide.ChampionName);
        AddChampionCandidate(candidates, guide.ChampionKey);
        return candidates
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select(name => $"https://opgg-static.akamaized.net/meta/images/lol/latest/champion/{name}.png?image=q_auto%3Agood%2Cf_png%2Cw_120")
            .ToList();
    }

    static void AddChampionCandidate(List<string> candidates, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        var clean = value.Trim()
            .Replace("'", string.Empty)
            .Replace(".", string.Empty)
            .Replace(" ", string.Empty)
            .Replace("&", string.Empty);

        if (!string.IsNullOrWhiteSpace(clean))
        {
            candidates.Add(clean);
            candidates.Add(char.ToUpperInvariant(clean[0]) + clean[1..]);
        }
    }
}

<div class="guide-page game-page">
    <div class="guide-hero game-page-header">
        <div>
            <div class="section-kicker">ARAM Mayhem</div>
            <h1 class="game-page-title">英雄資料庫</h1>
            <p class="game-page-description">依英雄定位、人工判斷與推薦摘要，快速找到本場海克斯與裝備方向。</p>
        </div>

        <form asp-action="Index" method="get" class="guide-search game-toolbar" id="guideSearchForm">
            <div class="guide-search-grid">
                @if (isPickMode)
                {
                    <input type="hidden" name="pick" value="champion" />
                }
                <input type="text" name="searchString" value="@currentFilter" class="form-control text-bg-dark border-secondary" placeholder="搜尋英雄、key 或定位" />
                <button class="btn btn-outline-info guide-search-button" type="submit">
                    <i class="bi bi-search"></i> 搜尋
                </button>
                @if (!string.IsNullOrWhiteSpace(currentFilter))
                {
                    <a asp-action="Index"
                       asp-route-pick="@(isPickMode ? "champion" : null)"
                       class="btn btn-outline-secondary"
                       title="清除搜尋">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </div>
        </form>

        @if (isAdmin)
        {
            <div class="guide-actions">
                <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#opGgChampionAugmentsModal">
                    <i class="bi bi-cloud-download me-1"></i>匯入全英雄
                </button>
                <a asp-action="Create" class="btn btn-info text-dark fw-bold">
                    <i class="bi bi-plus-circle me-1"></i>新增英雄
                </a>
            </div>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-bg-success border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show text-bg-danger border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!isAdmin)
    {
        <div class="alert alert-secondary border-0 mb-4" role="alert">
            <i class="bi bi-lock-fill me-2"></i>一般使用者只能瀏覽知識庫，新增、編輯、刪除與 OP.GG 匯入僅限管理員使用。
        </div>
    }

    @if (isPickMode)
    {
        <div class="pick-mode-banner">
            <i class="bi bi-cursor-fill me-2"></i>
            點選英雄卡片後會自動帶回 AI 推薦頁。
            <a asp-controller="AiRecommendation" asp-action="Index" class="btn btn-outline-info btn-sm ms-auto">
                <i class="bi bi-arrow-left me-1"></i>回 AI 推薦
            </a>
        </div>
    }

    <section id="guideResults">
        <div class="guide-count">@Model.Count 筆資料</div>
        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                目前沒有英雄知識資料。
            </div>
        }
        else
        {
            <div class="guide-grid">
                @foreach (var guide in Model)
                {
                    var championImageUrls = BuildChampionImageUrls(guide);
                    var championImageCandidates = string.Join("|", championImageUrls);
                    var augmentBadges = ParseAugmentBadges(guide.Augments, augmentCatalog);
                    var coreItems = SplitValues(guide.CoreItems).Take(4).ToList();

                    <article class="guide-card game-card @(isPickMode ? "pick-card" : "")"
                             data-pick-card="@(isPickMode ? "champion" : null)"
                             data-champion-name="@(!string.IsNullOrWhiteSpace(guide.LocalizedName) ? guide.LocalizedName : guide.ChampionName)"
                             data-champion-key="@guide.ChampionKey"
                             tabindex="@(isPickMode ? "0" : null)"
                             role="@(isPickMode ? "button" : null)"
                             aria-label="@(isPickMode ? $"選擇 {guide.LocalizedName}" : null)">
                        @if (isPickMode)
                        {
                            <div class="pick-card-ribbon">
                                <i class="bi bi-mouse2-fill me-1"></i>選擇並返回
                            </div>
                        }
                        <div class="guide-card-top">
                            <div class="guide-avatar">
                                @if (championImageUrls.Count > 0)
                                {
                                    <img
                                        src="@championImageUrls[0]"
                                        alt="@guide.LocalizedName"
                                        loading="lazy"
                                        decoding="async"
                                        referrerpolicy="no-referrer"
                                        data-image-index="0"
                                        data-image-candidates="@championImageCandidates"
                                        onerror="const c=(this.dataset.imageCandidates||'').split('|').filter(Boolean); const i=(Number(this.dataset.imageIndex)||0)+1; if(i<c.length){this.dataset.imageIndex=i; this.src=c[i];} else {this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');}" />
                                    <span class="guide-avatar-fallback d-none"><i class="bi bi-person-bounding-box"></i></span>
                                }
                                else
                                {
                                    <span class="guide-avatar-fallback"><i class="bi bi-person-bounding-box"></i></span>
                                }
                            </div>
                            <div class="min-w-0">
                                <div class="guide-name">@guide.LocalizedName</div>
                                <div class="guide-key">@guide.ChampionName ｜ key:@guide.ChampionKey</div>
                            </div>
                        </div>

                        <div class="guide-meta">
                            <span class="mode-badge">隨機單中大亂鬥</span>
                            <span class="patch-badge">@guide.PatchVersion</span>
                        </div>

                        <p class="guide-summary">@guide.RoleSummary</p>

                        <div>
                            <div class="mini-title">核心裝備</div>
                            <div class="pill-list">
                                @if (coreItems.Count == 0)
                                {
                                    <span class="info-pill muted">待人工補齊</span>
                                }
                                else
                                {
                                    @foreach (var item in coreItems)
                                    {
                                        <span class="info-pill">@item</span>
                                    }
                                }
                            </div>
                        </div>

                        <div>
                            <div class="mini-title">推薦海克斯</div>
                            <div class="augment-badge-list">
                                @if (augmentBadges.Count == 0)
                                {
                                    <span class="augment-mini-badge rarity-unknown">待人工補齊</span>
                                }
                                else
                                {
                                    @foreach (var augment in augmentBadges.Take(8))
                                    {
                                        <span class="augment-mini-badge @RarityClass(augment.Rarity) @TierClass(augment.Tier)">
                                            <span>@augment.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(augment.Tier))
                                            {
                                                <strong>@augment.Tier</strong>
                                            }
                                        </span>
                                    }
                                    @if (augmentBadges.Count > 8)
                                    {
                                        <span class="augment-mini-badge rarity-unknown">+@(augmentBadges.Count - 8)</span>
                                    }
                                }
                            </div>
                        </div>

                        <div class="guide-card-footer">
                            <span class="updated-time">@guide.UpdatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</span>
                            <div class="guide-card-actions">
                                <a asp-action="Details" asp-route-id="@guide.Id" class="icon-action" title="查看">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@guide.Id" class="icon-action action-edit" title="編輯">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@guide.Id" method="post" onsubmit="return confirm('確定要刪除這筆英雄知識嗎？');">
                                        <button type="submit" class="icon-action action-delete" title="刪除">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    @if (isAdmin)
    {
        <div class="modal fade" id="opGgChampionAugmentsModal" tabindex="-1" data-bs-theme="dark">
            <div class="modal-dialog">
                <div class="modal-content border-warning shadow-lg">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title fw-bold">
                            <i class="bi bi-cloud-download me-2"></i>從 OP.GG 匯入全英雄推薦海克斯
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="ImportChampionAugmentsFromOpGg" method="post">
                        <div class="modal-body">
                            <label for="opGgSourceUrl" class="form-label text-warning fw-bold">OP.GG ARAM Mayhem 主頁</label>
                            <input
                                type="url"
                                id="opGgSourceUrl"
                                name="sourceUrl"
                                class="form-control text-bg-dark border-secondary"
                                value="https://op.gg/zh-tw/lol/modes/aram-mayhem"
                                required />

                            <label for="startIndex" class="form-label text-warning fw-bold mt-3">起始順位</label>
                            <input
                                type="number"
                                id="startIndex"
                                name="startIndex"
                                class="form-control text-bg-dark border-secondary"
                                min="1"
                                value="1" />
                            <div class="form-text text-secondary">
                                英雄會固定依英文 key A-Z 排序。若要從第 21 位一路匯到最後，起始順位填 21、數量填 0。
                            </div>

                            <label for="maxHeroes" class="form-label text-warning fw-bold mt-3">匯入英雄數量</label>
                            <input
                                type="number"
                                id="maxHeroes"
                                name="maxHeroes"
                                class="form-control text-bg-dark border-secondary"
                                min="0"
                                value="20" />
                            <div class="form-text text-secondary">
                                填 0 代表從起始順位匯入到最後；系統會逐一讀取英雄頁，並放慢請求間隔。
                            </div>

                            <div class="alert alert-warning border-0 mt-3 mb-0">
                                若 OP.GG 暫時限制請求，等幾分鐘後用下一個起始順位接著匯入即可。
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                            <button type="submit" class="btn btn-outline-warning" onclick="document.getElementById('maxHeroes').value='0';">
                                <i class="bi bi-fast-forward-circle me-1"></i>匯入到最後
                            </button>
                            <button type="submit" class="btn btn-warning text-dark fw-bold">
                                <i class="bi bi-cloud-download me-1"></i>開始匯入
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
<style>
    .guide-page {
        color: #edf7f7;
        max-width: 1800px;
        margin: 0 auto;
    }

    .guide-hero {
        display: grid;
        grid-template-columns: minmax(320px, 1fr) minmax(420px, 0.9fr);
        gap: 20px;
        align-items: center;
        min-height: 210px;
        padding: 20px;
        border: 1px solid rgba(37, 215, 232, 0.22);
        background:
            linear-gradient(110deg, rgba(5, 15, 24, 0.96) 0%, rgba(7, 18, 28, 0.9) 54%, rgba(10, 26, 36, 0.74) 100%),
            url('/images/守岸.jpg') center / cover no-repeat;
        box-shadow: inset 0 0 0 1px rgba(255, 211, 101, 0.05), 0 22px 54px rgba(0, 0, 0, 0.28);
        position: relative;
        overflow: hidden;
    }

    .guide-hero::after {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 3px;
        background: linear-gradient(90deg, #25d7e8, #d4af37, transparent);
        opacity: 0.82;
    }

    .guide-hero > * {
        position: relative;
        z-index: 1;
    }

    .guide-hero h2 {
        color: #25d7e8;
        font-size: clamp(2rem, 4vw, 3.15rem);
        font-weight: 850;
        text-shadow: 0 0 28px rgba(37, 215, 232, 0.24);
    }

    .section-kicker,
    .guide-count {
        color: #25d7e8;
        font-size: 0.75rem;
        font-weight: 850;
        text-transform: uppercase;
    }

    .guide-search-grid {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(78px, auto) auto;
        gap: 8px;
        align-items: center;
    }

    .guide-search {
        padding: 14px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: rgba(4, 12, 19, 0.76);
        backdrop-filter: blur(8px);
    }

    .guide-search-button {
        min-width: 78px;
        white-space: nowrap;
    }

    .guide-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
        grid-column: 2;
    }

    .guide-count {
        margin-bottom: 9px;
    }

    .empty-state {
        border: 1px solid rgba(69, 214, 224, 0.24);
        background: rgba(4, 15, 26, 0.72);
        color: #8ea5ae;
        padding: 48px 20px;
        text-align: center;
    }

    .guide-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 14px;
    }

    .guide-card {
        position: relative;
        min-height: 350px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 16px;
        background: linear-gradient(145deg, rgba(5, 18, 31, 0.96), rgba(6, 24, 35, 0.86));
        border: 1px solid rgba(33, 187, 198, 0.34);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
        transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    }

    .guide-card:hover {
        transform: translateY(-7px) scale(1.012);
        border-color: rgba(37, 215, 232, 0.68);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28), inset 0 0 0 1px rgba(255, 211, 101, 0.08);
        animation: cardHop 520ms cubic-bezier(.2, 1.35, .34, 1);
    }

    .guide-card.pick-card {
        cursor: pointer;
        outline: 1px solid rgba(37, 215, 232, 0.2);
    }

    .guide-card.pick-card:focus-visible {
        outline: 3px solid rgba(37, 215, 232, 0.9);
        outline-offset: 3px;
    }

    .pick-card-ribbon {
        position: absolute;
        right: 14px;
        top: 14px;
        z-index: 3;
        display: inline-flex;
        align-items: center;
        padding: 5px 9px;
        color: #06121a;
        background: linear-gradient(135deg, #25d7e8, #ffe082);
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 900;
        box-shadow: 0 10px 22px rgba(37, 215, 232, 0.24);
    }

    .pick-mode-banner {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        padding: 12px 14px;
        color: #dffbff;
        background: rgba(37, 215, 232, 0.1);
        border: 1px solid rgba(37, 215, 232, 0.34);
        border-radius: 8px;
        box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
    }

    @@keyframes cardHop {
        0% { transform: translateY(0) scale(1); }
        48% { transform: translateY(-9px) scale(1.018); }
        72% { transform: translateY(-5px) scale(1.01); }
        100% { transform: translateY(-7px) scale(1.012); }
    }

    .guide-card::after {
        content: "";
        position: absolute;
        right: -1px;
        bottom: -1px;
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, transparent 50%, #062736 50%);
        border-left: 1px solid rgba(33, 187, 198, 0.25);
    }

    .guide-card-top {
        display: grid;
        grid-template-columns: 64px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
    }

    .guide-avatar,
    .guide-avatar-fallback {
        width: 64px;
        height: 64px;
        border-radius: 5px;
        background: #07111d;
        border: 1px solid rgba(37, 215, 232, 0.38);
        overflow: hidden;
    }

    .guide-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .guide-avatar-fallback {
        display: grid;
        place-items: center;
        color: #25d7e8;
        font-size: 1.45rem;
    }

    .guide-name {
        color: #fff;
        font-size: 1.05rem;
        font-weight: 850;
        overflow-wrap: anywhere;
    }

    .guide-key {
        color: #8ea5ae;
        font-size: 0.84rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .guide-meta,
    .pill-list,
    .augment-badge-list,
    .guide-card-footer,
    .guide-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .guide-summary {
        min-height: 66px;
        margin: 0;
        color: #cbd7dc;
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .mini-title {
        margin-bottom: 7px;
        color: #25d7e8;
        font-size: 0.78rem;
        font-weight: 850;
    }

    .mode-badge,
    .patch-badge,
    .info-pill,
    .augment-mini-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        min-height: 24px;
        border-radius: 3px;
        padding: 3px 8px;
        font-size: 0.74rem;
        font-weight: 800;
        line-height: 1.2;
    }

    .mode-badge,
    .patch-badge {
        color: #d9f9ff;
        background: rgba(37, 215, 232, 0.12);
        border: 1px solid rgba(37, 215, 232, 0.35);
    }

    .patch-badge {
        color: #fff0c4;
        border-color: rgba(224, 184, 91, 0.54);
        background: rgba(137, 105, 39, 0.3);
    }

    .info-pill {
        color: #ddfff5;
        background: rgba(38, 121, 111, 0.28);
        border: 1px solid rgba(105, 222, 204, 0.34);
    }

    .info-pill.muted {
        color: #b6cad2;
        background: rgba(118, 136, 143, 0.18);
        border-color: rgba(142, 165, 174, 0.25);
    }

    .augment-mini-badge {
        max-width: 190px;
    }

    .augment-mini-badge span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .augment-mini-badge strong {
        min-width: 20px;
        padding: 1px 4px;
        border-radius: 3px;
        text-align: center;
        background: rgba(255, 255, 255, 0.14);
    }

    .rarity-prismatic { color: #f1dcff; background: rgba(142, 82, 187, 0.55); border: 1px solid rgba(223, 173, 255, 0.5); }
    .rarity-gold { color: #fff0c4; background: rgba(137, 105, 39, 0.58); border: 1px solid rgba(224, 184, 91, 0.54); }
    .rarity-silver { color: #f2fbff; background: rgba(112, 130, 143, 0.52); border: 1px solid rgba(190, 215, 226, 0.5); }
    .rarity-unknown { color: #d9f9ff; background: rgba(37, 215, 232, 0.12); border: 1px solid rgba(37, 215, 232, 0.35); }
    .tier-s { box-shadow: inset 3px 0 0 #f4d35e; }
    .tier-a { box-shadow: inset 3px 0 0 #8de2ff; }
