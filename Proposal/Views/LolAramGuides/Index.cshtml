    @@media (max-width: 575px) {
        .guide-search-grid,
        .guide-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
}

@section Scripts {
<script>
    (() => {
        const form = document.getElementById('guideSearchForm');
        if (form) {
            form.addEventListener('submit', () => {
                form.action = `${window.location.pathname}#guideResults`;
            });
        }

        if (window.location.search.includes('searchString=')) {
            document.getElementById('guideResults')?.scrollIntoView({ block: 'start' });
        }

        const returnUrl = '@Url.Action("Index", "AiRecommendation")';
        const draftKey = 'aramAiRecommendationDraft';
        const pickCards = Array.from(document.querySelectorAll('[data-pick-card="champion"]'));

        const readDraft = () => {
            try {
                return JSON.parse(sessionStorage.getItem(draftKey) || '{}');
            } catch {
                return {};
            }
        };

        const chooseChampion = (card) => {
            const draft = readDraft();
            draft.coreChampion = card.dataset.championName || card.dataset.championKey || '';
            draft.augmentStages ??= {};
            sessionStorage.setItem(draftKey, JSON.stringify(draft));
            window.location.href = returnUrl;
        };

        for (const card of pickCards) {
            card.addEventListener('click', (event) => {
                if (event.target.closest('a, button, form, input, select, textarea')) {
                    return;
                }

                chooseChampion(card);
            });

            card.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    chooseChampion(card);
                }
            });
        }
    })();
</script>
}
