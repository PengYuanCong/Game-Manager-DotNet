@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string ActiveNav(params string[] controllers) =>
        controllers.Any(controller => string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase))
            ? "active"
            : string.Empty;

    string AvatarFileName(string? username)
    {
        var safeName = new string((username ?? "anonymous")
            .Where(character => char.IsAsciiLetterOrDigit(character) || character is '_' or '-' or '.')
            .ToArray());

        return $"{(string.IsNullOrWhiteSpace(safeName) ? "anonymous" : safeName)}.jpg";
    }
}

<!DOCTYPE html>
<html lang="zh-TW" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 彭彭遊戲基地</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <a class="skip-link" href="#main-content">跳到主要內容</a>
    <nav class="navbar navbar-expand-xl app-navbar">
        <div class="container-fluid app-navbar__inner">
            <a asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center gap-2">
                <i class="bi bi-controller fs-3" aria-hidden="true"></i>
                <span>彭彭遊戲基地</span>
            </a>

            <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="切換導覽">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav nav-primary">
                    <li class="nav-item">
                        <a asp-controller="AiRecommendation" asp-action="Index" class="nav-link @ActiveNav("AiRecommendation")">
                            <i class="bi bi-stars" aria-hidden="true"></i>AI 推薦
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="LolAramGuides" asp-action="Index" class="nav-link @ActiveNav("LolAramGuides")">
                            <i class="bi bi-person-vcard" aria-hidden="true"></i>英雄
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="LolAramAugments" asp-action="Index" class="nav-link @ActiveNav("LolAramAugments")">
                            <i class="bi bi-gem" aria-hidden="true"></i>海克斯
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Equipment" asp-action="Index" class="nav-link @ActiveNav("Equipment")">
                            <i class="bi bi-shield-sword" aria-hidden="true"></i>裝備
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav nav-utility">
                    <li class="nav-item">
                        <a asp-controller="Calculator" asp-action="Index" class="nav-link @ActiveNav("Calculator", "Colculator")">
                            <i class="bi bi-calculator" aria-hidden="true"></i>公式
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Media" asp-action="Highlights" class="nav-link @ActiveNav("Media")">
                            <i class="bi bi-play-btn" aria-hidden="true"></i>精彩操作
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="User" asp-action="Profile" class="nav-link @ActiveNav("User")">
                            <i class="bi bi-person-circle" aria-hidden="true"></i>個人資料
                        </a>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-2">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="user-chip d-flex align-items-center gap-2 text-white">
                            <img src="/avatars/@AvatarFileName(User.Identity.Name)" onerror="this.src='https://github.com/mdo.png'" alt="使用者頭像" width="32" height="32" class="rounded-circle" style="object-fit: cover;">
                            <strong>@User.Identity.Name</strong>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="登出">
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                                <span class="visually-hidden">登出</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-info text-dark fw-bold">
                            登入系統
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main id="main-content" class="main-content" tabindex="-1">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
