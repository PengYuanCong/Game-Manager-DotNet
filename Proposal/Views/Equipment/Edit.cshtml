@model Proposal.Models.Equipment

@{
    ViewData["Title"] = "修改裝備";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-secondary bg-dark text-light">
                <div class="card-header border-secondary bg-transparent py-3">
                    <h4 class="mb-0 text-light"><i class="bi bi-pencil-square text-info me-2"></i>裝備調整</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="DataDragonId" />
                        <input type="hidden" asp-for="ItemTags" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label text-info fw-bold">裝備名稱</label>
                            <input asp-for="Name" class="form-control text-bg-dark border-secondary" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemImageUrl" class="form-label text-info">圖片網址</label>
                            <input asp-for="ItemImageUrl" class="form-control text-bg-dark border-secondary" placeholder="可選，Data Dragon 匯入會自動填入" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="ItemDescription" class="form-label text-info">裝備介紹 / 效果文字</label>
                            <textarea asp-for="ItemDescription" class="form-control text-bg-dark border-secondary" rows="5" placeholder="例如：唯一被動、主動效果、適合搭配的海克斯或英雄。"></textarea>
                            <div class="form-text text-secondary">可保留 Data Dragon 匯入內容，也可以改成你自己的繁中整理。</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="HP" class="form-label text-danger">增加血量 (HP)</label>
                                <input asp-for="HP" type="number" class="form-control text-bg-dark border-secondary" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label text-warning">裝備價格</label>
                                <input asp-for="Price" type="number" class="form-control text-bg-dark border-secondary" />
                            </div>
                        </div>

                        <div class="row border border-secondary rounded p-2 mb-3 mx-0 bg-opacity-10 bg-white">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Attack" class="form-label">⚔️ 物理攻擊力</label>
                                <input asp-for="Attack" type="number" class="form-control text-bg-dark border-secondary" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MagicAttack" class="form-label text-primary">✨ 魔法攻擊力</label>
                                <input asp-for="MagicAttack" type="number" class="form-control text-bg-dark border-secondary" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhysicalDefense" class="form-label text-warning">🛡️ 物理防禦力</label>
                                <input asp-for="PhysicalDefense" type="number" class="form-control text-bg-dark border-secondary" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MagicDefense" class="form-label text-info">🔮 魔法防禦力</label>
                                <input asp-for="MagicDefense" type="number" class="form-control text-bg-dark border-secondary" />
                            </div>
                        </div>

                        <div class="border border-secondary rounded p-3 mb-3 bg-opacity-10 bg-white">
                            <h6 class="text-info fw-bold mb-3">英雄聯盟進階屬性</h6>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Mana" class="form-label">法力</label>
                                    <input asp-for="Mana" type="number" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="AbilityHaste" class="form-label">技能急速</label>
                                    <input asp-for="AbilityHaste" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="AttackSpeed" class="form-label">攻速 %</label>
                                    <input asp-for="AttackSpeed" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="CriticalStrikeChance" class="form-label">爆擊率 %</label>
                                    <input asp-for="CriticalStrikeChance" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MoveSpeed" class="form-label">固定跑速</label>
                                    <input asp-for="MoveSpeed" type="number" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MoveSpeedPercent" class="form-label">跑速 %</label>
                                    <input asp-for="MoveSpeedPercent" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Lethality" class="form-label">物理致命</label>
                                    <input asp-for="Lethality" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="ArmorPenetrationPercent" class="form-label">物理穿透 %</label>
                                    <input asp-for="ArmorPenetrationPercent" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MagicPenetration" class="form-label">固定魔穿</label>
                                    <input asp-for="MagicPenetration" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="MagicPenetrationPercent" class="form-label">魔法穿透 %</label>
                                    <input asp-for="MagicPenetrationPercent" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="HealthRegen" class="form-label">回血 %</label>
                                    <input asp-for="HealthRegen" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="ManaRegen" class="form-label">回魔 %</label>
                                    <input asp-for="ManaRegen" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="LifeSteal" class="form-label">生命偷取 %</label>
                                    <input asp-for="LifeSteal" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Omnivamp" class="form-label">全能吸血 %</label>
                                    <input asp-for="Omnivamp" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="HealAndShieldPower" class="form-label">治療護盾強度 %</label>
                                    <input asp-for="HealAndShieldPower" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Tenacity" class="form-label">韌性 %</label>
                                    <input asp-for="Tenacity" type="number" step="0.01" class="form-control text-bg-dark border-secondary" />
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">取消返回</a>
                            <button type="submit" class="btn btn-info text-white">
                                <i class="bi bi-save me-1"></i> 更新裝備資料
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
