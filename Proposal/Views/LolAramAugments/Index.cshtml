    static IReadOnlyList<string> SplitValues(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? Array.Empty<string>()
            : value.Split(new[] { ';', ',', '，', '、' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    static IReadOnlyList<string> BuildImageUrls(Proposal.Models.LolAramAugment augment)
    {
        var urls = new List<string>();
        AddDirectImageUrl(urls, augment.Notes);
        AddDirectImageUrl(urls, augment.SourceUrl);

        var imageNames = new List<string>();
        AddImageName(imageNames, ExtractOpGgImageName(augment.Notes));
        AddImageName(imageNames, ExtractOpGgImageName(augment.SourceUrl));

        var mappedImageName = FindKnownImageName(augment);
        AddImageName(imageNames, mappedImageName);

        foreach (var candidate in BuildImageNameCandidates(augment.AugmentKey))
        {
            AddImageName(imageNames, candidate);
        }

        foreach (var imageName in imageNames.Distinct(StringComparer.OrdinalIgnoreCase))
        {
            urls.Add(BuildOpGgImageUrl(imageName));
        }

        return urls.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
    }

    static string ExtractOpGgImageName(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes))
        {
            return string.Empty;
        }

        var pathIndex = notes.IndexOf("aram-augment/", StringComparison.OrdinalIgnoreCase);
        if (pathIndex >= 0)
        {
            var value = notes[(pathIndex + "aram-augment/".Length)..].Trim();
            var endIndex = value.IndexOfAny(new[] { '?', '&', ' ', '。', '；', ';', '\r', '\n', '"' });
            return endIndex >= 0 ? value[..endIndex].Trim() : value;
        }

        var markers = new[] { "OP.GG 圖片代碼：", "圖片代碼：", "image:", "Image:" };
        foreach (var marker in markers)
        {
            var index = notes.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
            if (index < 0)
            {
                continue;
            }

            var value = notes[(index + marker.Length)..].Trim();
            var endIndex = value.IndexOfAny(new[] { ' ', '。', '；', ';', '\r', '\n' });
            return endIndex >= 0 ? value[..endIndex].Trim() : value;
        }

        return string.Empty;
    }

