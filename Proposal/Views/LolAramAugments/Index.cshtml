    static IEnumerable<string> BuildImageNameCandidates(string key)
    {
        var pascal = ToPascalCase(key);
        if (string.IsNullOrWhiteSpace(pascal))
        {
            yield break;
        }

        yield return $"{pascal}_large.png";
        yield return $"ARAM_{pascal}_large.png";
        yield return $"{pascal}_large.Kiwi.png";
    }

    static string ToPascalCase(string value)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Any(ch => ch > 127))
        {
            return string.Empty;
        }

        var parts = value.Split(new[] { '_', '-', ' ' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Select(part => char.ToUpperInvariant(part[0]) + part[1..].ToLowerInvariant()));
    }

    static void AddImageName(List<string> imageNames, string? imageName)
    {
        if (string.IsNullOrWhiteSpace(imageName))
        {
            return;
        }

        imageName = imageName.Trim();
        if (!imageName.EndsWith(".png", StringComparison.OrdinalIgnoreCase))
        {
            imageName += ".png";
        }

        imageNames.Add(imageName);
    }

    static void AddDirectImageUrl(List<string> urls, string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return;
        }

        foreach (var part in text.Split(new[] { ' ', '\r', '\n', ';', '；' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var value = part.Trim('。', '"', '\'');
            if (value.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                && value.Contains("/aram-augment/", StringComparison.OrdinalIgnoreCase))
            {
                urls.Add(value);
            }
        }
    }

    static string BuildOpGgImageUrl(string imageName)
    {
        return $"https://opgg-static.akamaized.net/meta/images/lol/latest/aram-augment/{imageName}?image=q_auto%3Agood%2Cf_png%2Cw_120&v=1779191455";
    }

}

<div class="augment-page game-page">
    <div class="augment-hero game-page-header">
        <div class="augment-title-panel">
            <div class="section-kicker">ARAM Mayhem Arsenal</div>
            <h1 class="game-page-title">海克斯資料庫</h1>
            <p class="game-page-description">依評級、稀有度、套裝與屬性快速檢索本輪候選。</p>
        </div>

        <div class="augment-control-panel game-toolbar">
            <form asp-action="Index" method="get" class="augment-search" id="augmentSearchForm">
                <div class="augment-search-grid">
                    @if (isPickMode)
                    {
                        <input type="hidden" name="pick" value="augment" />
                        <input type="hidden" name="stage" value="@pickStage" />
                        <input type="hidden" name="slot" value="@pickSlot" />
                    }
                    <input type="text" name="searchString" value="@currentFilter" class="form-control text-bg-dark border-secondary" placeholder="搜尋名稱、代碼、套裝或屬性" />
                    @if (!string.IsNullOrWhiteSpace(selectedTag))
                    {
                        <input type="hidden" name="tag" value="@selectedTag" />
                    }
                    <select name="rarity" class="form-select text-bg-dark border-secondary" aria-label="依顏色篩選">
                        <option value="" selected="@string.IsNullOrWhiteSpace(selectedRarity)">全部顏色</option>
                        <option value="prismatic" selected="@(selectedRarity == "prismatic")">稜彩階</option>
                        <option value="gold" selected="@(selectedRarity == "gold")">黃金階</option>
                        <option value="silver" selected="@(selectedRarity == "silver")">白銀階</option>
                    </select>
                    <select name="seriesKey" class="form-select text-bg-dark border-secondary" aria-label="依套裝系列篩選">
                        <option value="" selected="@string.IsNullOrWhiteSpace(selectedSeries)">全部套裝</option>
                        @foreach (var option in seriesOptions)
                        {
                            <option value="@option.Value" selected="@(selectedSeries == option.Value)">@option.Text</option>
                        }
                    </select>
                    <button class="btn btn-outline-info augment-search-button" type="submit">
                        <i class="bi bi-search"></i> 搜尋
                    </button>
                    @if (!string.IsNullOrWhiteSpace(currentFilter) || !string.IsNullOrWhiteSpace(selectedRarity) || !string.IsNullOrWhiteSpace(selectedSeries) || !string.IsNullOrWhiteSpace(selectedTag))
                    {
                        <a asp-action="Index"
                           asp-route-pick="@(isPickMode ? "augment" : null)"
                           asp-route-stage="@(isPickMode ? pickStage : null)"
                           asp-route-slot="@(isPickMode ? pickSlot : null)"
                           class="btn btn-outline-secondary"
                           title="清除搜尋">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>

            <div class="augment-tag-drawer" id="augmentTagDrawer">
                <button
                    type="button"
                    class="tag-drawer-toggle"
                    id="augmentTagToggle"
                    aria-controls="augmentTagPanel"
                    aria-expanded="false">
                    <i class="bi bi-chevron-right"></i>
                    <span>屬性</span>
                </button>
                <div class="augment-tag-panel" id="augmentTagPanel" aria-label="海克斯標籤快速搜尋">
                    @for (var tagIndex = 0; tagIndex < tagFilters.Length; tagIndex++)
                    {
                        var tag = tagFilters[tagIndex];
                        var isActiveTag = selectedTag == tag.Value;
                        <a asp-action="Index"
                           asp-route-searchString="@currentFilter"
                           asp-route-rarity="@selectedRarity"
                           asp-route-seriesKey="@selectedSeries"
                           asp-route-tag="@tag.Value"
                           asp-route-pick="@(isPickMode ? "augment" : null)"
                           asp-route-stage="@(isPickMode ? pickStage : null)"
                           asp-route-slot="@(isPickMode ? pickSlot : null)"
                           class="tag-filter-button @TagClass(tag.Value) @(isActiveTag ? "active" : "")"
                           style="--tag-i:@tagIndex">
                            <i class="bi @tag.Icon"></i>@tag.Text
                        </a>
                    }
                </div>
            </div>

            @if (isAdmin)
            {
                <div class="augment-actions">
                    <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#opGgImportModal">
                        <i class="bi bi-cloud-download me-1"></i>從 OP.GG 匯入
                    </button>
                    <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#importAugmentsModal">
                        <i class="bi bi-upload me-1"></i>匯入檔案
                    </button>
                    <a asp-action="Create" class="btn btn-info text-dark fw-bold">
                        <i class="bi bi-plus-circle me-1"></i>新增海克斯
                    </a>
                </div>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-bg-success border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show text-bg-danger border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!isAdmin)
    {
        <div class="alert alert-secondary border-0 mb-4" role="alert">
            <i class="bi bi-lock-fill me-2"></i>一般使用者只能瀏覽海克斯知識庫，匯入與編輯功能僅限管理員使用。
        </div>
    }

    @if (isPickMode)
    {
        <div class="pick-mode-banner">
            <i class="bi bi-cursor-fill me-2"></i>
            點選海克斯卡片後，會放進目前階段的第 @((pickSlot ?? 0) + 1) 個選項並返回 AI 推薦頁。
            <a asp-controller="AiRecommendation" asp-action="Index" class="btn btn-outline-info btn-sm ms-auto">
                <i class="bi bi-arrow-left me-1"></i>回 AI 推薦
            </a>
        </div>
    }

    <section id="augmentResults">
        <div class="d-flex align-items-center justify-content-between mb-3 gap-3">
            <div>
                <div class="section-kicker">@Model.Count 筆資料</div>
                <h5 class="m-0">海克斯列表</h5>
            </div>
            @if (!string.IsNullOrWhiteSpace(currentFilter))
            {
                <span class="badge rounded-pill text-bg-info text-dark">搜尋：@currentFilter</span>
            }
            @if (!string.IsNullOrWhiteSpace(selectedRarity))
            {
                <span class="badge rounded-pill text-bg-warning text-dark">顏色：@DisplayRarity(selectedRarity)</span>
            }
            @if (!string.IsNullOrWhiteSpace(selectedSeries))
            {
                <span class="badge rounded-pill text-bg-secondary">套裝：@DisplaySeries(selectedSeries)</span>
            }
            @if (!string.IsNullOrWhiteSpace(selectedTag))
            {
                <span class="badge rounded-pill text-bg-info text-dark">屬性：@DisplayTag(selectedTag)</span>
            }
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                目前沒有符合條件的海克斯資料。
            </div>
        }
        else
        {
            <div class="augment-grid">
                @foreach (var augment in Model)
                {
                    var imageUrls = BuildImageUrls(augment);
                    var imageCandidates = string.Join("|", imageUrls);
                    var tags = SplitValues(augment.Tags)
                        .Select(DisplayTag)
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList();

                    <article class="augment-card game-card @RarityClass(augment.Rarity) @(isPickMode ? "pick-card" : "")"
                             data-pick-card="@(isPickMode ? "augment" : null)"
                             data-augment-name="@augment.Name"
                             data-augment-rarity="@DisplayRarity(augment.Rarity)"
                             data-pick-stage="@pickStage"
                             data-pick-slot="@pickSlot"
                             tabindex="@(isPickMode ? "0" : null)"
                             role="@(isPickMode ? "button" : null)"
                             aria-label="@(isPickMode ? $"選擇 {augment.Name}" : null)">
                        @if (isPickMode)
                        {
                            <div class="pick-card-ribbon">
                                <i class="bi bi-mouse2-fill me-1"></i>選擇並返回
                            </div>
                        }
                        <div class="augment-card-top">
                            <div class="augment-icon">
                                @if (imageUrls.Count > 0)
                                {
                                    <img
                                        src="@imageUrls[0]"
                                        alt="@augment.Name"
                                        loading="lazy"
                                        decoding="async"
                                        referrerpolicy="no-referrer"
                                        data-image-index="0"
                                        data-image-candidates="@imageCandidates"
                                        onerror="const c=(this.dataset.imageCandidates||'').split('|').filter(Boolean); const i=(Number(this.dataset.imageIndex)||0)+1; if(i<c.length){this.dataset.imageIndex=i; this.src=c[i];} else {this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');}" />
                                    <i class="bi bi-stars d-none"></i>
                                }
                                else
                                {
                                    <i class="bi bi-stars"></i>
                                }
                            </div>
                            <div class="min-w-0">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                    <span class="rarity-badge @RarityClass(augment.Rarity)">@DisplayRarity(augment.Rarity)</span>
                                    @if (!string.IsNullOrWhiteSpace(augment.Tier))
                                    {
                                        <span class="tier-badge">@augment.Tier</span>
                                    }
                                </div>
                                <h3>@augment.Name</h3>
                                <div class="small text-secondary text-truncate" title="@augment.AugmentKey">@augment.AugmentKey</div>
                            </div>
                        </div>

                        <p class="augment-effect">@augment.EffectText</p>

                        <div class="augment-meta">
                            <span class="series-badge @SeriesClass(augment.SeriesKey)">
                                <i class="bi bi-diagram-3"></i>@DisplaySeries(augment.SeriesKey)
                            </span>
                            <span class="mode-badge">@DisplayMode(augment.ModeName)</span>
                        </div>

                        <div class="tag-list">
                            @if (tags.Count == 0)
                            {
                                <span class="tag-pill tag-default">未標記</span>
                            }
                            else
                            {
                                foreach (var tag in tags)
                                {
                                    <span class="tag-pill @TagClass(tag)">@tag</span>
                                }
                            }
                        </div>

                        <div class="augment-card-footer">
                            <span class="small text-secondary">@augment.PatchVersion</span>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@augment.Id" class="icon-action" title="查看">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@augment.Id" class="icon-action action-edit" title="編輯">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@augment.Id" method="post" onsubmit="return confirm('確定要刪除這筆海克斯資料嗎？');">
                                        <button type="submit" class="icon-action action-delete" title="刪除">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <div class="set-assist" id="setAssist" style="left: calc(100vw - 92px); top: calc(50vh - 32px);">
        <div class="set-assist-orbit">
            @for (var index = 0; index < setEffects.Length; index++)
            {
                var item = setEffects[index];
                <button
                    type="button"
                    class="set-orbit-button"
                    style="--i:@index"
                    data-set-name="@item.Name"
                    data-set-max="@item.Max"
                    data-set-effect="@item.Effect"
                    title="@item.Name">
                    <span class="set-orbit-icon"><i class="bi @item.Icon"></i></span>
                    <span class="set-orbit-label">@item.Name</span>
                </button>
            }
        </div>
        <button type="button" class="set-assist-main" id="setAssistToggle" aria-label="套裝效果" aria-expanded="false">
            <span class="poro-mark" aria-hidden="true">
                <span class="poro-horn poro-horn-left"></span>
                <span class="poro-horn poro-horn-right"></span>
                <span class="poro-eye poro-eye-left"></span>
                <span class="poro-eye poro-eye-right"></span>
                <span class="poro-nose"></span>
                <span class="poro-tongue"></span>
            </span>
        </button>
    </div>

    <div class="modal fade" id="setEffectModal" tabindex="-1" data-bs-theme="dark">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content set-effect-modal">
                <div class="modal-header border-secondary">
                    <div>
                        <div class="section-kicker" id="setEffectMax">MAX</div>
                        <h5 class="modal-title" id="setEffectTitle">套裝效果</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="setEffectText" class="set-effect-text mb-0"></p>
                </div>
            </div>
        </div>
    </div>

    @if (isAdmin)
    {
        <div class="modal fade" id="opGgImportModal" tabindex="-1" data-bs-theme="dark">
            <div class="modal-dialog">
                <div class="modal-content border-info shadow-lg">
                    <div class="modal-header bg-info text-dark">
                        <h5 class="modal-title fw-bold">
                            <i class="bi bi-cloud-download me-2"></i>從 OP.GG 匯入海克斯
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="ImportFromOpGg" method="post">
                        <div class="modal-body">
                            <label for="opGgSourceUrl" class="form-label text-info fw-bold">OP.GG ARAM Mayhem 頁面</label>
                            <input
                                type="url"
                                id="opGgSourceUrl"
                                name="sourceUrl"
                                class="form-control text-bg-dark border-secondary"
                                value="https://op.gg/zh-tw/lol/modes/aram-mayhem"
                                required />
                            <div class="form-text text-secondary mt-2">
                                會抓取公開頁面中的海克斯名稱、效果文字、OP.GG 評級與推薦英雄，並轉成 RAG 可使用的資料。
                            </div>
                            <div class="alert alert-info border-0 mt-3 mb-0">
                                匯入時會用 OP.GG 圖片代碼作為海克斯代碼，同名或同代碼資料會更新，不會重複新增。
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                            <button type="submit" class="btn btn-info text-dark fw-bold">
                                <i class="bi bi-cloud-download me-1"></i>開始匯入
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="importAugmentsModal" tabindex="-1" data-bs-theme="dark">
            <div class="modal-dialog modal-lg">
                <div class="modal-content border-warning shadow-lg">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title fw-bold">
                            <i class="bi bi-upload me-2"></i>匯入海克斯資料
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Import" method="post" enctype="multipart/form-data">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="importFile" class="form-label text-info fw-bold">JSON 或 CSV 檔案</label>
                                <input type="file" id="importFile" name="importFile" class="form-control text-bg-dark border-secondary" accept=".json,.csv" required />
                            </div>

                            <div class="alert alert-secondary border-0 mb-3">
                                系統會用 <code>AugmentKey + ModeName</code> 判斷是否為同一筆資料。沒有填代碼時，會依照名稱自動產生。
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <h6 class="text-warning">CSV 欄位範例</h6>
                                    <code class="d-block text-light small">
                                        AugmentKey,Name,Rarity,Tier,SeriesKey,EffectText,Tags,SynergyNotes,PatchVersion,SourceUrl,Notes
                                    </code>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-warning">JSON 範例</h6>
                                    <pre class="text-light small bg-black border border-secondary rounded p-2 mb-0">[
  {
    "augmentKey": "grandma_spicy_oil",
    "name": "阿嬤的辣油",
    "rarity": "prismatic",
    "tier": "S",
    "seriesKey": null,
    "effectText": "施加燃燒時產生辣油區域。",
    "tags": "burn; healing; area; stackosaurus"
  }
]</pre>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                            <button type="submit" class="btn btn-warning text-dark fw-bold">
                                <i class="bi bi-upload me-1"></i>開始匯入
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
<style>
    .augment-page {
        color: #edf7f7;
        max-width: 1800px;
        margin: 0 auto;
    }

    .augment-hero {
        display: grid;
        grid-template-columns: minmax(320px, 0.72fr) minmax(620px, 1.28fr);
        gap: 20px;
        align-items: center;
        min-height: 230px;
        padding: 20px;
        border: 1px solid rgba(37, 215, 232, 0.22);
        background:
            linear-gradient(110deg, rgba(5, 15, 24, 0.96) 0%, rgba(7, 18, 28, 0.88) 52%, rgba(10, 26, 36, 0.72) 100%),
            url('/images/守岸.jpg') center / cover no-repeat;
        box-shadow: inset 0 0 0 1px rgba(255, 211, 101, 0.05), 0 22px 54px rgba(0, 0, 0, 0.28);
        overflow: hidden;
        position: relative;
    }

    .augment-hero::after {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 3px;
        background: linear-gradient(90deg, #25d7e8, #d4af37, transparent);
        opacity: 0.82;
    }

    .augment-title-panel,
    .augment-control-panel {
        position: relative;
        z-index: 1;
    }

    .augment-title-panel {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 10px;
    }

    .augment-hero h2 {
        color: #25d7e8;
        font-weight: 800;
        font-size: clamp(2rem, 4vw, 3.35rem);
        text-shadow: 0 0 28px rgba(37, 215, 232, 0.24);
    }

    .augment-title-panel p {
        max-width: 560px;
        margin: 0;
        color: #b8c8d1;
        line-height: 1.7;
    }

    .section-kicker {
        color: #25d7e8;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .augment-control-panel {
        align-self: center;
        display: grid;
        align-content: start;
        grid-auto-rows: max-content;
        gap: 12px;
        min-height: 0;
        padding: 16px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: rgba(4, 12, 19, 0.76);
        backdrop-filter: blur(8px);
    }

    .augment-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
    }

    .augment-search-grid {
        display: grid;
        grid-template-columns: minmax(190px, 1fr) 128px 148px minmax(78px, auto) auto;
        gap: 8px;
        align-items: center;
    }

    .augment-search-button {
        min-width: 78px;
        white-space: nowrap;
    }

    .augment-tag-drawer {
        display: flex;
        gap: 8px;
        align-items: flex-start;
        align-self: start;
        justify-self: start;
        height: auto;
        max-height: 44px;
        width: fit-content;
        max-width: 100%;
        min-width: 0;
        min-height: 38px;
        overflow: hidden;
        padding: 3px;
        border: 1px solid rgba(37, 215, 232, 0.22);
        background: linear-gradient(90deg, rgba(37, 215, 232, 0.09), rgba(7, 15, 22, 0.38));
    }

    .augment-tag-drawer.open {
        width: min(100%, 680px);
        max-height: min(420px, calc(100vh - 120px));
        overflow: auto;
    }

    .tag-drawer-toggle {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 36px;
        padding: 7px 12px;
        color: #06111c;
        background: #25d7e8;
        border: 1px solid rgba(37, 215, 232, 0.8);
        border-radius: 999px;
        font-weight: 900;
        box-shadow: 0 10px 24px rgba(37, 215, 232, 0.14);
        transition: background-color 160ms ease, color 160ms ease, transform 160ms ease;
    }

    .tag-drawer-toggle:hover {
        transform: translateX(2px);
        background: #7cf1ff;
    }

    .tag-drawer-toggle i {
        transition: transform 180ms ease;
    }

    .augment-tag-drawer.open .tag-drawer-toggle i {
        transform: rotate(180deg);
    }

    .augment-tag-panel {
        display: none;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        align-self: center;
        padding: 1px 0;
        min-width: 0;
        max-width: 0;
        opacity: 0;
        pointer-events: none;
        overflow: hidden;
        transform: translateX(-18px);
        transition: max-width 260ms ease, opacity 160ms ease, transform 220ms cubic-bezier(.2,.85,.3,1.12);
    }

    .augment-tag-drawer.open .augment-tag-panel {
        display: flex;
        max-width: calc(100% - 92px);
        opacity: 1;
        pointer-events: auto;
        transform: translateX(0);
    }

    .tag-filter-button {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 34px;
        padding: 6px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 800;
        text-decoration: none;
        opacity: 0;
        transform: translateX(-14px) scale(0.96);
        transition:
            opacity 150ms ease,
            transform 190ms cubic-bezier(.2,.85,.3,1.16),
            border-color 150ms ease,
            background-color 150ms ease,
            box-shadow 150ms ease;
        transition-delay: 0ms;
    }

    .augment-tag-drawer.open .tag-filter-button {
        opacity: 1;
        transform: translateX(0) scale(1);
        transition-delay: calc(var(--tag-i) * 18ms);
    }

    .tag-filter-button:hover,
    .tag-filter-button.active {
        transform: translateY(-1px) scale(1.02);
        border-color: #25d7e8;
        box-shadow: 0 0 0 1px rgba(37, 215, 232, 0.32), 0 8px 18px rgba(0, 0, 0, 0.24);
    }

    .empty-state {
        border: 1px solid rgba(69, 214, 224, 0.24);
        background: rgba(4, 15, 26, 0.72);
        color: #8ea5ae;
        padding: 48px 20px;
        text-align: center;
    }

    .augment-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 14px;
    }

    .augment-card {
        position: relative;
        min-height: 256px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 16px;
        background: linear-gradient(145deg, rgba(5, 18, 31, 0.96), rgba(6, 24, 35, 0.86));
        border: 1px solid rgba(33, 187, 198, 0.34);
        border-radius: 4px;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
        overflow: hidden;
        transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    }

    .augment-card:hover {
        transform: translateY(-7px) scale(1.014);
        border-color: rgba(37, 215, 232, 0.74);
