@section Scripts {
<script>
    (() => {
        const form = document.getElementById('augmentSearchForm');
        if (form) {
            form.addEventListener('submit', () => {
                form.action = `${window.location.pathname}#augmentResults`;
            });
        }

        if (window.location.search) {
            document.getElementById('augmentResults')?.scrollIntoView({ block: 'start' });
        }

        const tagDrawer = document.getElementById('augmentTagDrawer');
        const tagToggle = document.getElementById('augmentTagToggle');
        tagToggle?.addEventListener('click', () => {
            const isOpen = tagDrawer?.classList.toggle('open') ?? false;
            tagToggle.setAttribute('aria-expanded', String(isOpen));
        });

        const assist = document.getElementById('setAssist');
        const toggle = document.getElementById('setAssistToggle');
        const modalElement = document.getElementById('setEffectModal');
        const modal = modalElement ? new bootstrap.Modal(modalElement) : null;
        const title = document.getElementById('setEffectTitle');
        const max = document.getElementById('setEffectMax');
        const text = document.getElementById('setEffectText');
        let pointerId = null;
        let originX = 0;
        let originY = 0;
        let startLeft = 0;
        let startTop = 0;
        let moved = false;

        const clamp = (value, min, maxValue) => Math.max(min, Math.min(value, maxValue));
        const toggleAssist = () => {
            const isOpen = assist.classList.toggle('open');
            toggle.setAttribute('aria-expanded', String(isOpen));
        };

        toggle?.addEventListener('pointerdown', event => {
            pointerId = event.pointerId;
            originX = event.clientX;
            originY = event.clientY;
            const rect = assist.getBoundingClientRect();
            startLeft = rect.left;
            startTop = rect.top;
            moved = false;
            assist.classList.add('dragging');
            toggle.setPointerCapture(pointerId);
        });

        toggle?.addEventListener('pointermove', event => {
            if (pointerId !== event.pointerId) {
                return;
            }

            const dx = event.clientX - originX;
            const dy = event.clientY - originY;
            if (Math.abs(dx) + Math.abs(dy) > 6) {
                moved = true;
            }

            const nextLeft = clamp(startLeft + dx, 12, window.innerWidth - 76);
            const nextTop = clamp(startTop + dy, 76, window.innerHeight - 76);
            assist.style.left = `${nextLeft}px`;
            assist.style.top = `${nextTop}px`;
        });

        toggle?.addEventListener('pointerup', event => {
            if (pointerId === event.pointerId) {
                toggle.releasePointerCapture(pointerId);
                pointerId = null;
                assist.classList.remove('dragging');

                if (!moved) {
                    toggleAssist();
                }

                moved = false;
            }
        });

        toggle?.addEventListener('click', event => {
            event.preventDefault();
        });

        document.querySelectorAll('.set-orbit-button').forEach(button => {
            button.addEventListener('click', () => {
                title.textContent = button.dataset.setName || '套裝效果';
                max.textContent = button.dataset.setMax || '';
                text.textContent = button.dataset.setEffect || '';
                assist.classList.remove('open');
                toggle?.setAttribute('aria-expanded', 'false');
                modal?.show();
            });
        });

        const returnUrl = '@Url.Action("Index", "AiRecommendation")';
        const draftKey = 'aramAiRecommendationDraft';
        const stageLabels = {
            opening: '開局三選一',
            level7: '7 等三選一',
            level11: '11 等三選一',
            level15: '15 等三選一'
        };
        const pickCards = Array.from(document.querySelectorAll('[data-pick-card="augment"]'));

        const readDraft = () => {
            try {
                return JSON.parse(sessionStorage.getItem(draftKey) || '{}');
            } catch {
                return {};
            }
        };

        const chooseAugment = (card) => {
            const stage = card.dataset.pickStage || 'opening';
            const rawSlot = Number(card.dataset.pickSlot ?? 0);
            const slot = Number.isFinite(rawSlot) ? Math.max(0, Math.min(rawSlot, 2)) : 0;
            const draft = readDraft();
            draft.augmentStages ??= {};
            draft.augmentStages[stage] ??= ['', '', ''];
            draft.augmentStages[stage][slot] = card.dataset.augmentName || '';
            draft.augmentChoiceRarities ??= {};
            draft.augmentChoiceRarities[stage] ??= ['', '', ''];
            draft.augmentChoiceRarities[stage][slot] = card.dataset.augmentRarity || '';
            draft.currentStage = stageLabels[stage] || draft.currentStage || '';
            sessionStorage.setItem(draftKey, JSON.stringify(draft));
            window.location.href = returnUrl;
        };

        for (const card of pickCards) {
            card.addEventListener('click', event => {
                if (event.target.closest('a, button, form, input, select, textarea')) {
                    return;
                }

                chooseAugment(card);
            });

            card.addEventListener('keydown', event => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    chooseAugment(card);
                }
            });
        }
    })();
</script>
}
