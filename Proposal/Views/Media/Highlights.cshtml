@model IEnumerable<Proposal.Models.VideoItem>

@{
    ViewData["Title"] = "精彩操作";
}

<section class="highlight-theater highlights-page game-page">
    <div class="highlight-hero game-page-header">
        <div>
            <div class="highlight-kicker game-kicker">HIGHLIGHT THEATER</div>
            <h1 class="game-page-title">精彩操作劇院</h1>
            <p class="game-page-description">搜尋 League of Legends 影片、預覽教學與操作精華，也可以拖曳本地影片快速播放。</p>
        </div>
        <div class="highlight-badges" aria-label="功能摘要">
            <span><i class="bi bi-youtube"></i>YouTube 搜尋</span>
            <span><i class="bi bi-film"></i>本地播放</span>
            <span><i class="bi bi-controller"></i>操作複盤</span>
        </div>
    </div>

    <div class="theater-grid">
        <aside class="video-sidebar game-card">
            <div class="sidebar-head">
                <div>
                    <div class="highlight-kicker">Search Queue</div>
                    <h2>搜尋清單</h2>
                </div>
                <i class="bi bi-play-btn"></i>
            </div>

            <div class="search-dock">
                <label class="form-label" for="ytSearchInput">關鍵字</label>
                <div class="input-group">
                    <input type="text" id="ytSearchInput" class="form-control rift-input" placeholder="例如：ARAM Mayhem Swain">
                    <button class="btn rift-primary" type="button" onclick="handleSearch()">
                        <i class="bi bi-search me-1"></i>搜尋
                    </button>
                </div>
            </div>

            <div id="videoList" class="video-list">
                <div class="queue-empty">
                    <i class="bi bi-search-heart"></i>
                    <strong>等待搜尋</strong>
                    <span>搜尋後的影片會出現在這裡。</span>
                </div>
            </div>
        </aside>

        <main class="player-stage game-card">
            <div class="stage-topline">
                <span><i class="bi bi-broadcast-pin"></i> Preview Console</span>
                <span>16:9</span>
            </div>

            <div class="video-viewport" id="playerContainer">
                <div class="player-empty">
                    <i class="bi bi-play-circle"></i>
                    <strong>選擇影片開始預覽</strong>
                    <span>從左側搜尋結果或本地拖曳影片開始。</span>
                </div>
            </div>

            <div id="dropZone" class="drop-zone">
                <input id="fileInput" type="file" accept="video/*" class="d-none">
                <div>
                    <i class="bi bi-cloud-arrow-up"></i>
                    <strong>拖曳本地影片到這裡</strong>
                    <span>支援瀏覽器可播放的影片格式。</span>
                </div>
                <button type="button" class="btn rift-outline" onclick="document.getElementById('fileInput').click()">
                    <i class="bi bi-folder2-open me-1"></i>選擇檔案
                </button>
            </div>
        </main>
    </div>
</section>

@section Styles {
<style>
    .highlight-theater {
        padding-bottom: 46px;
    }

    .highlight-hero,
    .video-sidebar,
    .player-stage {
        border: 1px solid rgba(34, 232, 255, 0.24);
        background:
            linear-gradient(135deg, rgba(3, 16, 24, 0.96), rgba(5, 32, 43, 0.9)),
            repeating-linear-gradient(90deg, rgba(34, 232, 255, 0.045) 0 1px, transparent 1px 58px);
        box-shadow: 0 22px 70px rgba(0, 0, 0, 0.32);
    }

    .highlight-hero {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        align-items: end;
        min-height: 168px;
        padding: clamp(26px, 5vw, 48px);
        margin-bottom: 22px;
        border-color: rgba(216, 182, 92, 0.28);
        background:
            linear-gradient(110deg, rgba(3, 11, 16, 0.96) 0%, rgba(6, 31, 42, 0.88) 58%, rgba(255, 0, 0, 0.09) 100%),
            radial-gradient(circle at 84% 20%, rgba(216, 182, 92, 0.16), transparent 22rem),
            repeating-linear-gradient(90deg, rgba(34, 232, 255, 0.045) 0 1px, transparent 1px 58px);
    }

    .highlight-kicker {
        color: #22e8ff;
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .highlight-hero h1 {
        margin: 8px 0 12px;
        color: #fff4c7;
        font-size: clamp(2rem, 4vw, 3.8rem);
        font-weight: 950;
        line-height: 0.95;
    }

    .highlight-hero p {
        max-width: 640px;
        margin: 0;
        color: #c8e8ef;
        line-height: 1.85;
    }

    .highlight-badges {
        display: grid;
        gap: 10px;
        min-width: min(100%, 260px);
    }

    .highlight-badges span {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        min-height: 46px;
        padding: 10px 12px;
        border: 1px solid rgba(34, 232, 255, 0.32);
        color: #f5fbff;
        background: rgba(0, 0, 0, 0.25);
        font-weight: 900;
    }

    .highlight-badges i {
        color: #d8b65c;
        font-size: 1.1rem;
    }

    .theater-grid {
        display: grid;
        grid-template-columns: minmax(310px, 390px) minmax(0, 1fr);
        gap: 22px;
        min-height: 640px;
    }

    .video-sidebar,
    .player-stage {
        padding: 22px;
    }

    .sidebar-head,
    .stage-topline {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
    }

    .sidebar-head {
        margin-bottom: 20px;
    }

    .sidebar-head h2 {
        margin: 5px 0 0;
        color: #fff4c7;
        font-size: 1.45rem;
        font-weight: 950;
    }

    .sidebar-head > i {
        display: grid;
        place-items: center;
        width: 48px;
        height: 48px;
        color: #22e8ff;
        border: 1px solid rgba(34, 232, 255, 0.42);
        background: rgba(34, 232, 255, 0.08);
        font-size: 1.35rem;
    }

    .form-label {
        color: #22e8ff;
        font-size: 0.86rem;
        font-weight: 900;
    }

    .rift-input {
        min-height: 46px;
        border-radius: 0;
        border: 1px solid rgba(164, 190, 198, 0.45);
        color: #fff;
        background: rgba(255, 255, 255, 0.075);
    }

    .rift-input:focus {
        color: #fff;
        border-color: #22e8ff;
        background: rgba(34, 232, 255, 0.08);
        box-shadow: 0 0 0 0.18rem rgba(34, 232, 255, 0.16);
    }

    .rift-primary,
    .rift-outline {
        min-height: 46px;
        border-radius: 0;
        font-weight: 950;
        white-space: nowrap;
    }

    .rift-primary {
        border: 1px solid rgba(34, 232, 255, 0.85);
        color: #031017;
        background: linear-gradient(135deg, #18d5f0, #9ee996);
    }

    .rift-outline {
        border: 1px solid rgba(34, 232, 255, 0.62);
        color: #22e8ff;
        background: rgba(34, 232, 255, 0.06);
    }

    .video-list {
        display: grid;
        gap: 12px;
        max-height: 470px;
        margin-top: 18px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .video-item {
        cursor: pointer;
        padding: 10px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.22);
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .video-item:hover {
        transform: translateY(-3px);
        border-color: rgba(34, 232, 255, 0.58);
        background: rgba(34, 232, 255, 0.08);
    }

    .video-thumb {
        width: 92px;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border: 1px solid rgba(34, 232, 255, 0.25);
        background: #000;
    }

    .video-title {
        color: #f4fbff;
        font-size: 0.9rem;
        font-weight: 850;
        line-height: 1.35;
    }

    .video-channel {
        color: #92adba;
        font-size: 0.78rem;
    }

    .queue-empty,
    .player-empty {
        display: grid;
        place-items: center;
        align-content: center;
        gap: 8px;
        min-height: 190px;
        text-align: center;
        color: #93b5bf;
    }

    .queue-empty i,
    .player-empty i {
        color: #22e8ff;
        font-size: 2rem;
    }

    .player-stage {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .stage-topline {
        color: #9ab6c0;
        font-size: 0.9rem;
        font-weight: 900;
    }

    .stage-topline span:first-child {
        color: #22e8ff;
    }

    .video-viewport {
        width: 100%;
        aspect-ratio: 16 / 9;
        display: grid;
        place-items: center;
        background:
            radial-gradient(circle at center, rgba(34, 232, 255, 0.12), transparent 45%),
            #000;
        border: 1px solid rgba(34, 232, 255, 0.26);
        box-shadow: inset 0 0 70px rgba(34, 232, 255, 0.08);
        overflow: hidden;
    }

    .video-viewport iframe,
    .video-viewport video {
        width: 100%;
        height: 100%;
        border: 0;
        object-fit: contain;
        background: #000;
    }

    .drop-zone {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        min-height: 118px;
        padding: 18px;
        border: 1px dashed rgba(34, 232, 255, 0.38);
        color: #f5fbff;
        background: rgba(34, 232, 255, 0.05);
        transition: background 0.18s ease, border-color 0.18s ease;
    }

    .drop-zone.active {
        border-color: #d8b65c;
        background: rgba(216, 182, 92, 0.12);
    }

    .drop-zone div {
        display: grid;
        gap: 4px;
    }

    .drop-zone i {
        color: #22e8ff;
        font-size: 1.5rem;
    }

    .drop-zone strong {
        color: #fff4c7;
        font-weight: 950;
    }

    .drop-zone span {
        color: #93b5bf;
        font-size: 0.9rem;
    }

    @@media (max-width: 1100px) {
        .highlight-hero {
            align-items: start;
            flex-direction: column;
        }

        .theater-grid {
            grid-template-columns: 1fr;
        }

        .video-list {
            max-height: 340px;
        }
    }

    @@media (max-width: 640px) {
        .drop-zone,
        .input-group {
            display: grid;
        }

        .input-group .form-control,
        .input-group .btn {
            width: 100%;
        }
    }
</style>
}

<script>
    function escapeHtml(value) {
        return String(value ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    async function handleSearch() {
        try {
            const query = document.getElementById("ytSearchInput").value.trim();
            if (!query) {
                return;
            }

            const videoList = document.getElementById("videoList");
            videoList.innerHTML = `
                <div class="queue-empty">
                    <div class="spinner-border text-info" role="status"></div>
                    <strong>搜尋中</strong>
                    <span>正在向 YouTube API 取得影片。</span>
                </div>`;

            const response = await fetch(`/Media/GetYouTubeVideos?query=${encodeURIComponent(query)}`);

            if (!response.ok) {
                throw new Error("API 請求失敗");
            }

            const data = await response.json();
            videoList.innerHTML = "";

            if (!data.items || data.items.length === 0) {
                videoList.innerHTML = `
                    <div class="queue-empty">
                        <i class="bi bi-emoji-neutral"></i>
                        <strong>沒有找到影片</strong>
                        <span>換個英雄名稱或關鍵字再試一次。</span>
                    </div>`;
                return;
            }

            data.items.forEach(item => {
                const videoId = item.id?.videoId;
                if (!videoId) {
                    return;
                }

                const title = escapeHtml(item.snippet?.title);
                const thumb = escapeHtml(item.snippet?.thumbnails?.default?.url);
                const channel = escapeHtml(item.snippet?.channelTitle);

                const div = document.createElement("div");
                div.className = "video-item";
                div.innerHTML = `
                    <div class="d-flex align-items-center gap-3">
                        <img src="${thumb}" alt="" class="video-thumb" loading="lazy" referrerpolicy="no-referrer">
                        <div>
                            <div class="video-title">${title}</div>
                            <div class="video-channel">${channel}</div>
                        </div>
                    </div>`;
                div.onclick = () => playVideo(videoId);
                videoList.appendChild(div);
            });
        } catch (error) {
            console.error("Fetch Error:", error);
            document.getElementById("videoList").innerHTML = `
                <div class="queue-empty text-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>搜尋失敗</strong>
                    <span>請檢查 YouTube API 設定或稍後再試。</span>
                </div>`;
        }
    }

    function playVideo(videoId) {
        const container = document.getElementById("playerContainer");
        container.innerHTML = `
            <iframe
                src="https://www.youtube.com/embed/${encodeURIComponent(videoId)}?autoplay=1"
                title="YouTube video player"
                allow="autoplay; encrypted-media"
                allowfullscreen>
            </iframe>`;
    }

    const dropZone = document.getElementById("dropZone");
    const fileInput = document.getElementById("fileInput");

    if (dropZone) {
        dropZone.addEventListener("dragover", (event) => {
            event.preventDefault();
            dropZone.classList.add("active");
        });

        dropZone.addEventListener("dragleave", () => dropZone.classList.remove("active"));

        dropZone.addEventListener("drop", (event) => {
            event.preventDefault();
            dropZone.classList.remove("active");
            const file = event.dataTransfer.files[0];
            handleVideoFile(file);
        });
    }

    if (fileInput) {
        fileInput.addEventListener("change", (event) => {
            handleVideoFile(event.target.files[0]);
        });
    }

    function handleVideoFile(file) {
        if (file && file.type.startsWith("video/")) {
            const url = URL.createObjectURL(file);
            const container = document.getElementById("playerContainer");
            container.innerHTML = `<video controls autoplay><source src="${url}" type="${escapeHtml(file.type)}"></video>`;

            const videoList = document.getElementById("videoList");
            const newItem = document.createElement("div");
            newItem.className = "video-item";
            newItem.textContent = `[本地匯入] ${file.name}`;
            newItem.onclick = () => {
                container.innerHTML = `<video controls autoplay><source src="${url}" type="${escapeHtml(file.type)}"></video>`;
            };
            videoList.prepend(newItem);
        }
    }

    document.getElementById("ytSearchInput")?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
            event.preventDefault();
            handleSearch();
        }
    });
</script>
